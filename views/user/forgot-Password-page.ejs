<%- include("../../views/partials/user/header") %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
  rel="stylesheet"
/>
<style>
  :root {
    --ink: #161413;
    --ink-soft: #6f6a67;
    --line: #e5e0dc;
    --pink: #c2185b;
    --pink-tint: #fdf2f6;
    --error: #b3261e;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: "Inter", sans-serif;
    background: #fbfaf9;
    height: 100vh;
    overflow: hidden;
    color: var(--ink);
  }

  main {
    height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .forgot-container {
    width: 420px;
    max-width: 95vw;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 34px 42px;
    box-shadow: 0 20px 50px rgba(20, 18, 17, 0.06);
  }

  .lock-icon-wrap {
    text-align: center;
    margin-bottom: 14px;
  }

  .lock-icon-wrap i {
    font-size: 22px;
    color: var(--pink);
  }

  .form-heading {
    text-align: center;
    margin-bottom: 22px;
  }

  .form-heading h1 {
    font-size: 24px;
    font-weight: 800;
    letter-spacing: -0.01em;
    margin-bottom: 8px;
  }

  .form-heading p {
    font-size: 13px;
    color: var(--ink-soft);
    line-height: 1.6;
  }

  .form-group {
    margin-bottom: 18px;
  }

  .form-group label {
    display: block;
    font-size: 11.5px;
    color: var(--ink-soft);
    margin-bottom: 5px;
    font-weight: 500;
  }

  .input-icon {
    position: relative;
  }

  .input-icon input {
    padding-right: 34px;
  }

  .input-icon i {
    position: absolute;
    right: 10px;
    top: 32px;
    color: #b8b2ac;
    font-size: 13px;
    pointer-events: none;
  }

  .form-group input {
    width: 100%;
    padding: 9px 10px;
    border: 1.5px solid var(--line);
    border-radius: 8px;
    font-size: 13.5px;
    font-family: "Inter", sans-serif;
    color: var(--ink);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .form-group input::placeholder {
    color: #b8b2ac;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--pink);
    box-shadow: 0 0 0 3px var(--pink-tint);
  }

  .submit-btn {
    width: 100%;
    padding: 11px;
    background: var(--ink);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 13.5px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .submit-btn:hover {
    background: #e44786;
  }

  .submit-btn:focus-visible,
  .form-group input:focus-visible {
    outline: 2px solid var(--pink);
    outline-offset: 2px;
  }

  .back-link {
    text-align: center;
    font-size: 13px;
    color: var(--ink-soft);
    margin-top: 18px;
  }

  .back-link a {
    color: var(--pink);
    font-weight: 600;
    text-decoration: none;
  }

  .back-link a:hover {
    text-decoration: underline;
  }

  .error-msg {
    color: var(--error);
    font-size: 0.68rem;
    margin-top: 3px;
  }

  /* Responsive */
  @media (max-width: 500px) {
    main {
      padding: 12px;
    }
    .forgot-container {
      padding: 26px 24px;
    }
  }

  @media (max-height: 720px) {
    .forgot-container {
      padding: 24px 40px;
    }
    .form-heading {
      margin-bottom: 14px;
    }
  }
</style>

<main>
    <div class="forgot-container">

        <div class="lock-icon-wrap">
            <i class="fas fa-lock"></i>
        </div>

        <div class="form-heading">
            <h1>Forgot Password?</h1>
            <p>No worries! Enter your email and we'll<br>send you a reset link.</p>
        </div>

        <form id="forgotForm" action="/forgot-email-valid" method="POST" onsubmit="return validateForgotForm()" novalidate>
            <div class="form-group input-icon">
                <label for="emailInput">Email Address</label>
                <input type="text" name="email" id="emailInput" placeholder="muhsinapp@example.com">
                <i class="fas fa-envelope"></i>
                <div class="error-msg" id="emailError"></div>
            </div>

            <button type="submit" class="submit-btn">
                <i class="fas fa-paper-plane"></i>Send Reset Link
            </button>
        </form>

        <div class="back-link">
            Remember your password? <a href="/login">Back to Login</a>
        </div>

        <div class="back-link" style="margin-top:6px;">
            Don't have an account? <a href="/signup">Sign up</a>
        </div>

    </div>
</main>

<script>
    function validateForgotForm() {
        const emailInput = document.getElementById('emailInput');
        const emailError = document.getElementById('emailError');
        const emailValue = emailInput.value.trim();
        const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

        emailError.textContent = '';
        emailInput.style.borderColor = '';

        if (emailValue === '') {
            emailError.textContent = 'Email is required.';
            emailInput.style.borderColor = 'red';
            return false;
        } else if (!emailPattern.test(emailValue)) {
            emailError.textContent = 'Please enter a valid email address.';
            emailInput.style.borderColor = 'red';
            return false;
        }

        return true;
    }
</script>

<%- include("../../views/partials/user/footer") %>
