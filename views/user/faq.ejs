<%-include("../../views/partials/user/header")%>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FAQs – NUVE</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --brand:    #d4145a;
            --brand-dk: #a81049;
            --dark:     #1a1a1a;
            --mid:      #555;
            --light:    #f8f9fa;
            --white:    #ffffff;
            --border:   #e8e8e8;
        }

        body {
            font-family: 'Jost', 'Segoe UI', Tahoma, sans-serif;
            color: var(--dark);
            line-height: 1.7;
        }

        /* ── Hero ─────────────────────────────────────── */
        .faq-hero {
            position: relative;
            height: 340px;
            background: linear-gradient(135deg, #1a0a10 0%, #3d0e26 60%, #1a0a10 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .faq-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                radial-gradient(ellipse 55% 70% at 20% 50%, rgba(212,20,90,0.2) 0%, transparent 70%),
                radial-gradient(ellipse 40% 50% at 80% 30%, rgba(212,20,90,0.12) 0%, transparent 70%);
        }

        .faq-hero::after {
            content: 'NUVE';
            position: absolute;
            font-family: 'Cormorant Garamond', Georgia, serif;
            font-size: 220px;
            font-weight: 600;
            color: rgba(255,255,255,0.04);
            letter-spacing: 0.15em;
            pointer-events: none;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        .faq-hero-content {
            position: relative;
            z-index: 2;
            text-align: center;
            color: var(--white);
            animation: fadeInUp 0.9s ease both;
            padding: 0 20px;
        }

        .faq-hero-content .eyebrow {
            font-size: 13px;
            letter-spacing: 0.35em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.5);
            margin-bottom: 16px;
        }

        .faq-hero-content h1 {
            font-family: 'Cormorant Garamond', Georgia, serif;
            font-size: 56px;
            font-weight: 600;
            line-height: 1.1;
            margin-bottom: 16px;
        }

        .faq-hero-content h1 em {
            font-style: italic;
            color: #f2a0bf;
        }

        .faq-hero-content p {
            font-size: 16px;
            font-weight: 300;
            color: rgba(255,255,255,0.72);
            max-width: 480px;
            margin: 0 auto;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(28px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ── Search ───────────────────────────────────── */
        .faq-search-wrap {
            max-width: 560px;
            margin: -28px auto 0;
            position: relative;
            z-index: 3;
            padding: 0 20px;
        }

        .faq-search {
            position: relative;
            background: var(--white);
            border-radius: 50px;
            box-shadow: 0 12px 30px rgba(0,0,0,0.1);
        }

        .faq-search input {
            width: 100%;
            padding: 17px 24px 17px 52px;
            border: none;
            border-radius: 50px;
            font-family: 'Jost', sans-serif;
            font-size: 15px;
            color: var(--dark);
            outline: none;
            background: transparent;
        }

        .faq-search i {
            position: absolute;
            left: 22px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--brand);
            font-size: 15px;
        }

        /* ── Section shared ───────────────────────────── */
        .section-label {
            font-size: 12px;
            letter-spacing: 0.32em;
            text-transform: uppercase;
            color: var(--brand);
            font-weight: 600;
            margin-bottom: 14px;
            display: block;
        }

        .section-title {
            font-family: 'Cormorant Garamond', Georgia, serif;
            font-size: 36px;
            font-weight: 600;
            line-height: 1.2;
            margin-bottom: 6px;
        }

        /* ── FAQ Body ─────────────────────────────────── */
        .faq-section {
            padding: 70px 5% 100px;
            background: var(--white);
        }

        .faq-wrap {
            max-width: 800px;
            margin: 0 auto;
        }

        .faq-category {
            margin-bottom: 54px;
        }

        .faq-category:last-child {
            margin-bottom: 0;
        }

        .faq-category-head {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 22px;
        }

        .faq-category-icon {
            width: 40px;
            height: 40px;
            min-width: 40px;
            border-radius: 50%;
            background: rgba(212,20,90,0.1);
            color: var(--brand);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
        }

        .faq-category-head h3 {
            font-family: 'Cormorant Garamond', Georgia, serif;
            font-size: 24px;
            font-weight: 600;
            color: var(--dark);
        }

        .faq-list {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .faq-item {
            background: var(--light);
            border-radius: 12px;
            overflow: hidden;
            border: 1.5px solid var(--border);
            transition: border-color 0.25s, background 0.25s;
        }

        .faq-item.open {
            border-color: rgba(212,20,90,0.3);
            background: var(--white);
        }

        .faq-question {
            padding: 20px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            cursor: pointer;
            font-size: 15px;
            font-weight: 500;
            color: var(--dark);
            user-select: none;
        }

        .faq-question i {
            font-size: 13px;
            color: var(--brand);
            transition: transform 0.3s;
            flex-shrink: 0;
        }

        .faq-item.open .faq-question i {
            transform: rotate(180deg);
        }

        .faq-answer {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.35s ease, padding 0.3s;
            font-size: 15px;
            color: var(--mid);
            padding: 0 24px;
        }

        .faq-item.open .faq-answer {
            max-height: 260px;
            padding: 0 24px 20px;
        }

        .faq-empty {
            display: none;
            text-align: center;
            padding: 50px 20px;
            color: var(--mid);
            font-size: 15px;
        }

        .faq-empty i {
            font-size: 26px;
            color: var(--brand);
            margin-bottom: 12px;
            display: block;
        }

        /* ── Still Need Help CTA ──────────────────────── */
        .faq-cta {
            padding: 70px 5%;
            background: var(--light);
            text-align: center;
        }

        .faq-cta-inner {
            max-width: 520px;
            margin: 0 auto;
        }

        .faq-cta h2 {
            font-family: 'Cormorant Garamond', Georgia, serif;
            font-size: 32px;
            font-weight: 600;
            margin-bottom: 12px;
        }

        .faq-cta p {
            font-size: 15px;
            color: var(--mid);
            margin-bottom: 28px;
        }

        .btn-submit {
            background: var(--brand);
            color: var(--white);
            padding: 15px 40px;
            border: none;
            border-radius: 50px;
            font-family: 'Jost', sans-serif;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .btn-submit:hover {
            background: var(--brand-dk);
            transform: translateY(-2px);
            box-shadow: 0 10px 24px rgba(212,20,90,0.3);
        }

        .btn-submit i {
            font-size: 13px;
            transition: transform 0.3s;
        }

        .btn-submit:hover i {
            transform: translateX(4px);
        }

        /* ── Responsive ───────────────────────────────── */
        @media (max-width: 600px) {
            .faq-hero-content h1 { font-size: 34px; }
            .section-title { font-size: 28px; }
            .faq-category-head h3 { font-size: 20px; }
        }
    </style>
</head>
<body>

    <!-- ── Hero ──────────────────────────────────────── -->
    <section class="faq-hero">
        <div class="faq-hero-content">
            <p class="eyebrow">Support</p>
            <h1>Frequently Asked <em>Questions</em></h1>
            <p>Everything you need to know about orders, returns, sizing, and more.</p>
        </div>
    </section>

    <div class="faq-search-wrap">
        <div class="faq-search">
            <i class="fas fa-search"></i>
            <input type="text" id="faqSearch" placeholder="Search for a question..." oninput="filterFaqs(this.value)">
        </div>
    </div>

    <!-- ── FAQ Body ──────────────────────────────────── -->
    <section class="faq-section">
        <div class="faq-wrap">

            <!-- Orders & Shipping -->
            <div class="faq-category">
                <div class="faq-category-head">
                    <div class="faq-category-icon"><i class="fas fa-box"></i></div>
                    <h3>Orders &amp; Shipping</h3>
                </div>
                <div class="faq-list">
                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFaq(this)">
                            How long does delivery take?
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">Standard delivery within Kerala takes 2–4 business days. Pan-India orders are typically delivered within 5–7 business days. Express options are available at checkout.</div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFaq(this)">
                            How do I track my order?
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">Once your order ships, you'll receive a tracking link via email and SMS. You can also check order status anytime from your account dashboard under "My Orders".</div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFaq(this)">
                            Can I change or cancel my order after placing it?
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">You can cancel or edit an order within 1 hour of placing it from your account page. Once it's been packed for shipping, changes are no longer possible.</div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFaq(this)">
                            Do you ship internationally?
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">At the moment we only ship within India. We're working on international shipping and will announce it on our Instagram once it's live.</div>
                    </div>
                </div>
            </div>

            <!-- Returns & Exchanges -->
            <div class="faq-category">
                <div class="faq-category-head">
                    <div class="faq-category-icon"><i class="fas fa-rotate-left"></i></div>
                    <h3>Returns &amp; Exchanges</h3>
                </div>
                <div class="faq-list">
                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFaq(this)">
                            What is your return policy?
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">We accept returns within 7 days of delivery on unworn, unaltered items with original tags. Sale items are not eligible for return unless defective.</div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFaq(this)">
                            Do you offer size exchanges?
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">Yes! Size exchanges are free within 14 days of delivery. Simply contact us and we'll arrange a pickup and resend the correct size at no extra charge.</div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFaq(this)">
                            How long does a refund take to process?
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">Once we receive and inspect your return, refunds are processed within 3–5 business days to your original payment method, or instantly as store credit.</div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFaq(this)">
                            Who pays for return shipping?
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">Returns due to sizing or change of mind have a small pickup fee, deducted from your refund. Returns for defective or incorrect items are completely free.</div>
                    </div>
                </div>
            </div>

            <!-- Sizing & Fit -->
            <div class="faq-category">
                <div class="faq-category-head">
                    <div class="faq-category-icon"><i class="fas fa-ruler"></i></div>
                    <h3>Sizing &amp; Fit</h3>
                </div>
                <div class="faq-list">
                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFaq(this)">
                            How do I find my correct size?
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">Every product page has a "Size Guide" link with detailed measurements. We recommend measuring a similar garment you already own and comparing it to our chart.</div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFaq(this)">
                            Do your clothes run true to size?
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">Most of our pieces run true to size. Fitted styles like bodycon dresses are noted as "fits snug" on the product page, so you can size up if you prefer a looser fit.</div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFaq(this)">
                            What if an item is out of stock in my size?
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">Tap "Notify Me" on the product page and we'll email you the moment your size is restocked. Popular sizes are usually replenished within 2–3 weeks.</div>
                    </div>
                </div>
            </div>

            <!-- Payments & Account -->
            <div class="faq-category">
                <div class="faq-category-head">
                    <div class="faq-category-icon"><i class="fas fa-credit-card"></i></div>
                    <h3>Payments &amp; Account</h3>
                </div>
                <div class="faq-list">
                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFaq(this)">
                            What payment methods do you accept?
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">We accept all major credit and debit cards, UPI, net banking, and popular wallets. Cash on delivery is available for orders under ₹5,000.</div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFaq(this)">
                            Is it safe to save my card details?
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">Yes. Payments are processed through PCI-DSS compliant gateways, and we never store your full card number on our servers.</div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFaq(this)">
                            Do I need an account to place an order?
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">No, you can check out as a guest. Creating an account lets you track orders, save addresses, and earn rewards on future purchases though.</div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFaq(this)">
                            How do I apply a referral or promo code?
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">Enter your code in the "Referral / Promo Code" field at checkout or during signup, and the discount will be applied automatically before payment.</div>
                    </div>
                </div>
            </div>

            <div class="faq-empty" id="faqEmpty">
                <i class="fas fa-magnifying-glass"></i>
                <p>No questions matched your search. Try a different keyword, or reach out below.</p>
            </div>

        </div>
    </section>

    <!-- ── Still Need Help ───────────────────────────── -->
    <section class="faq-cta">
        <div class="faq-cta-inner">
            <span class="section-label" style="text-align:center;">Still Stuck?</span>
            <h2>We're Just a Message Away</h2>
            <p>Can't find what you're looking for? Our team is happy to help with anything else.</p>
            <a href="/contact-us" class="btn-submit">Contact Us <i class="fas fa-arrow-right"></i></a>
        </div>
    </section>

    <script>
        function toggleFaq(el) {
            const item = el.parentElement;
            const isOpen = item.classList.contains('open');

            document.querySelectorAll('.faq-item.open').forEach(i => i.classList.remove('open'));

            if (!isOpen) item.classList.add('open');
        }

        function filterFaqs(query) {
            const q = query.trim().toLowerCase();
            const categories = document.querySelectorAll('.faq-category');
            let anyVisible = false;

            categories.forEach(cat => {
                let categoryHasMatch = false;

                cat.querySelectorAll('.faq-item').forEach(item => {
                    const question = item.querySelector('.faq-question').textContent.toLowerCase();
                    const answer = item.querySelector('.faq-answer').textContent.toLowerCase();
                    const matches = question.includes(q) || answer.includes(q);

                    item.style.display = matches ? '' : 'none';
                    if (matches) categoryHasMatch = true;
                });

                cat.style.display = categoryHasMatch ? '' : 'none';
                if (categoryHasMatch) anyVisible = true;
            });

            document.getElementById('faqEmpty').style.display = (!anyVisible && q.length > 0) ? 'block' : 'none';
        }
    </script>

</body>
</html>
<%-include("../../views/partials/user/footer")%>
