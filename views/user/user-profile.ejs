<%- include("../../views/partials/user/header") %>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
  :root {
    --rose: #d4145a;
    --rose-deep: #e96495;
    --rose-pale: #fce8f0;
    --rose-blush: #f9d0e0;
    --rose-mist: #fff5f8;
    --ink: #1a1a2e;
    --ink-soft: #3d3d5c;
    --muted: #8a8aa0;
    --surface: #ffffff;
    --off-white: #fdfbfc;
    --border: #eedde5;
    --shadow-sm: 0 2px 12px rgba(212, 20, 90, 0.06);
    --shadow-md: 0 8px 32px rgba(212, 20, 90, 0.10);
    --shadow-lg: 0 20px 60px rgba(212, 20, 90, 0.14);
    --radius: 20px;
    --radius-sm: 12px;
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--off-white);
    font-family: 'DM Sans', sans-serif;
    color: var(--ink);
    min-height: 100vh;
  }

  .page-wrapper {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    padding: 48px 24px 80px;
  }

  .page-wrapper::before {
    content: '';
    position: fixed;
    top: -200px; right: -200px;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(212,20,90,0.08) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .page-wrapper::after {
    content: '';
    position: fixed;
    bottom: -200px; left: -150px;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(212,20,90,0.05) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .profile-container {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── Hero Banner ── */
  .profile-hero {
    position: relative;
    background: linear-gradient(135deg, var(--rose) 0%, var(--rose-deep) 55%, #6b003a 100%);
    border-radius: var(--radius);
    padding: 28px 48px 68px;
    overflow: hidden;
    margin-bottom: 0;
    box-shadow: var(--shadow-lg);
  }

  .profile-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 80% 20%, rgba(255,255,255,0.12) 0%, transparent 50%),
      url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Ccircle cx='30' cy='30' r='20'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }

  .hero-accent-ring {
    position: absolute;
    top: -80px; right: -80px;
    width: 300px; height: 300px;
    border: 60px solid rgba(255,255,255,0.06);
    border-radius: 50%;
  }

  .hero-accent-ring-2 {
    position: absolute;
    bottom: -60px; left: 20%;
    width: 200px; height: 200px;
    border: 40px solid rgba(255,255,255,0.04);
    border-radius: 50%;
  }

  .hero-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    margin-bottom: 12px;
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 600;
    color: white;
    line-height: 1.15;
    margin-bottom: 10px;
  }

  .hero-subtitle {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.65);
    font-weight: 300;
  }

  .avatar-float {
    position: absolute;
    right: 60px;
    top: 50%;
    transform: translateY(-50%);
  }

  .avatar-ring {
    width: 130px; height: 130px;
    border-radius: 50%;
    padding: 4px;
    background: linear-gradient(135deg, rgba(255,255,255,0.6), rgba(255,255,255,0.2));
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
  }

  .avatar-img {
    width: 100%; height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid white;
    display: block;
  }

  .avatar-edit-btn {
    position: absolute;
    bottom: 4px; right: 4px;
    width: 34px; height: 34px;
    border-radius: 50%;
    background: white;
    color: var(--rose);
    border: none;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.8rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    transition: var(--transition);
  }

  .avatar-edit-btn:hover {
    background: var(--rose);
    color: white;
    transform: scale(1.1);
  }

  /* ── Stats Strip ── */
  .stats-strip {
    background: white;
    border-radius: var(--radius);
    margin-top: -44px;
    position: relative;
    z-index: 2;
    box-shadow: var(--shadow-md);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    overflow: hidden;
  }

  .stat-item {
    padding: 28px 24px;
    text-align: center;
    border-right: 1px solid var(--border);
    transition: var(--transition);
  }

  .stat-item:last-child { border-right: none; }
  .stat-item:hover { background: var(--rose-mist); }

  .stat-value {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--rose);
    line-height: 1;
    margin-bottom: 6px;
  }

  .stat-label {
    font-size: 0.78rem;
    color: var(--muted);
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* ── Main content grid ── */
  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 24px;
  }

  .card {
    background: white;
    border-radius: var(--radius);
    padding: 36px;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border);
    transition: var(--transition);
  }

  .card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .card-full { grid-column: 1 / -1; }

  .card-header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
  }

  .card-title-group {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .card-icon {
    width: 40px; height: 40px;
    border-radius: 10px;
    background: var(--rose-pale);
    color: var(--rose);
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem;
  }

  .card-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--ink);
  }

  .card-action-link {
    font-size: 0.8rem;
    color: var(--rose);
    font-weight: 500;
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: var(--transition);
    display: flex; align-items: center; gap: 4px;
  }

  .card-action-link:hover { color: var(--rose-deep); gap: 8px; }

  /* ── Info rows ── */
  .info-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 0;
    border-bottom: 1px solid #f5f0f2;
  }

  .info-row:last-child { border-bottom: none; }

  .info-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-weight: 500;
  }

  .info-value {
    font-size: 0.95rem;
    color: var(--ink);
    font-weight: 500;
    text-align: right;
  }

  .info-value.password {
    color: var(--muted);
    font-family: monospace;
    letter-spacing: 0.2em;
  }

  /* ── Orders table ── */
  .orders-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0 6px;
  }

  .orders-table thead th {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    font-weight: 600;
    padding: 6px 16px;
    text-align: left;
    border-bottom: 2px solid var(--border);
    padding-bottom: 14px;
  }

  .orders-table tbody tr {
    background: var(--off-white);
    transition: var(--transition);
  }

  .orders-table tbody tr:hover { background: var(--rose-mist); }

  .orders-table tbody td {
    padding: 14px 16px;
    font-size: 0.9rem;
    color: var(--ink-soft);
  }

  .orders-table tbody td:first-child {
    border-radius: var(--radius-sm) 0 0 var(--radius-sm);
    font-weight: 600;
    color: var(--ink);
  }

  .orders-table tbody td:last-child {
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .badge-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 14px;
    border-radius: 50px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .badge-status::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .badge-delivered { background: #e8f8ef; color: #1a7a46; }
  .badge-delivered::before { background: #1a7a46; }
  .badge-pending { background: #fff4e0; color: #a06000; }
  .badge-pending::before { background: #f59e0b; }
  .badge-cancelled { background: #fdecea; color: #c0392b; }
  .badge-cancelled::before { background: #c0392b; }

  .view-link {
    color: var(--rose);
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 600;
    transition: var(--transition);
  }

  .view-link:hover { color: var(--rose-deep); }

  /* ── Bottom action buttons ── */
  .action-strip {
    margin-top: 28px;
    display: flex;
    gap: 16px;
    justify-content: center;
  }

  .btn-rose {
    padding: 14px 36px;
    border-radius: 50px;
    background: linear-gradient(135deg, var(--rose) 0%, var(--rose-deep) 100%);
    color: white;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(212,20,90,0.35);
    transition: var(--transition);
    letter-spacing: 0.03em;
    display: flex; align-items: center; gap: 8px;
    text-decoration: none;
  }

  .btn-rose:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(212,20,90,0.4);
    color: white;
  }

  .btn-ghost {
    padding: 14px 36px;
    border-radius: 50px;
    background: white;
    color: var(--ink-soft);
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    border: 1.5px solid var(--border);
    cursor: pointer;
    transition: var(--transition);
    letter-spacing: 0.03em;
    display: flex; align-items: center; gap: 8px;
    text-decoration: none;
  }

  .btn-ghost:hover {
    border-color: var(--rose);
    color: var(--rose);
    transform: translateY(-2px);
  }

  /* ══════════════════════════════════════
     ADDRESS SECTION — Redesigned
  ══════════════════════════════════════ */

  .addr-add-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 20px;
    border-radius: 50px;
    border: 1.5px solid var(--rose);
    color: var(--rose);
    font-size: 0.83rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: var(--transition);
    background: transparent;
  }

  .addr-add-btn:hover {
    background: var(--rose);
    color: white;
    box-shadow: 0 4px 16px rgba(212,20,90,0.25);
  }

  .addr-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 18px;
  }

  /* Individual address card */
  .addr-card {
    position: relative;
    border: 1.5px solid var(--border);
    border-radius: 16px;
    padding: 22px 22px 18px;
    background: #fff;
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .addr-card:hover {
    border-color: var(--rose-deep);
    box-shadow: 0 8px 28px rgba(212,20,90,0.10);
    transform: translateY(-3px);
  }

  .addr-card--default {
    border-color: var(--rose);
    background: var(--rose-mist);
  }

  /* Top row */
  .addr-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .addr-type-pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: var(--rose-pale);
    color: var(--rose);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 5px 13px;
    border-radius: 50px;
  }

  .addr-default-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--rose);
    background: rgba(212,20,90,0.08);
    border: 1px solid rgba(212,20,90,0.2);
    padding: 4px 11px;
    border-radius: 50px;
    letter-spacing: 0.02em;
  }

  /* Body */
  .addr-card__body {
    display: flex;
    flex-direction: column;
    gap: 5px;
    flex: 1;
  }

  .addr-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0;
  }

  .addr-line {
    font-size: 0.875rem;
    color: var(--ink-soft);
    margin: 0;
    line-height: 1.55;
  }

  .addr-landmark, .addr-phone {
    color: var(--muted);
    font-size: 0.82rem;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  /* Actions */
  .addr-card__actions {
    display: flex;
    gap: 10px;
    padding-top: 14px;
    border-top: 1px solid #f0eaec;
  }

  .addr-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 16px;
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    transition: var(--transition);
    letter-spacing: 0.02em;
    cursor: pointer;
    line-height: 1;
  }

  .addr-btn--edit {
    background: #eef2ff;
    color: #3b5bdb;
    border: 1.5px solid #c5d0fa;
  }

  .addr-btn--edit:hover {
    background: #3b5bdb;
    color: white;
    border-color: #3b5bdb;
    box-shadow: 0 3px 12px rgba(59,91,219,0.25);
    transform: translateY(-1px);
  }

  .addr-btn--delete {
    background: #fff0f0;
    color: #c0392b;
    border: 1.5px solid #f5c0bb;
  }

  .addr-btn--delete:hover {
    background: #c0392b;
    color: white;
    border-color: #c0392b;
    box-shadow: 0 3px 12px rgba(192,57,43,0.25);
    transform: translateY(-1px);
  }

  /* Empty state */
  .addr-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 52px 20px;
    text-align: center;
    gap: 10px;
  }

  .addr-empty__icon {
    width: 72px; height: 72px;
    border-radius: 50%;
    background: var(--rose-mist);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.8rem;
    color: var(--rose-blush);
    margin-bottom: 6px;
  }

  .addr-empty__title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0;
  }

  .addr-empty__sub {
    font-size: 0.88rem;
    color: var(--muted);
    margin: 0 0 10px;
  }

  .addr-add-btn--lg {
    padding: 12px 28px;
    font-size: 0.9rem;
    margin-top: 4px;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .profile-hero { padding: 36px 28px 90px; }
    .avatar-float { right: 24px; }
    .avatar-ring { width: 90px; height: 90px; }
    .content-grid { grid-template-columns: 1fr; }
    .stats-strip { grid-template-columns: 1fr; }
    .stat-item { border-right: none; border-bottom: 1px solid var(--border); }
    .action-strip { flex-direction: column; }
    .addr-grid { grid-template-columns: 1fr; }
  }

  /* ── Entrance animations ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .profile-hero      { animation: fadeUp 0.5s ease both; }
  .stats-strip       { animation: fadeUp 0.5s 0.1s ease both; }
  .content-grid .card:nth-child(1) { animation: fadeUp 0.5s 0.2s ease both; }
  .content-grid .card:nth-child(2) { animation: fadeUp 0.5s 0.28s ease both; }
  .content-grid .card:nth-child(3) { animation: fadeUp 0.5s 0.35s ease both; }
  .action-strip      { animation: fadeUp 0.5s 0.42s ease both; }
</style>

<div class="page-wrapper">
  <div class="profile-container">

    <!-- ── Hero Banner ── -->
    <div class="profile-hero">
      <div class="hero-accent-ring"></div>
      <div class="hero-accent-ring-2"></div>
      <p class="hero-label">My Account</p>
      <h1 class="hero-title">Welcome back,<br><%= user.name.split(' ')[0] %></h1>
      <p class="hero-subtitle">Manage your personal details, orders &amp; preferences</p>

      <div class="avatar-float">
        <div class="avatar-ring" style="position:relative;">
          <img
            src="<%= user.profileImage || 'images/heroin.jpg' %>"
            alt="Profile Photo"
            class="avatar-img"
            id="currentPhoto"
          >
          <label for="photoUpload" class="avatar-edit-btn" title="Change photo">
            <i class="fas fa-camera"></i>
          </label>
          <input type="file" id="photoUpload" name="image" accept="image/*" hidden>
        </div>
      </div>
    </div>

    <!-- ── Stats Strip ── -->
    <div class="stats-strip">
      <div class="stat-item">
        <div class="stat-value">0</div>
        <div class="stat-label">Total Orders</div>
      </div>
      <div class="stat-item">
        <div class="stat-value">0</div>
        <div class="stat-label">Delivered</div>
      </div>
      <div class="stat-item">
        <div class="stat-value">0</div>
        <div class="stat-label">Pending</div>
      </div>
    </div>

    <!-- ── Content Grid ── -->
    <div class="content-grid">

      <!-- Personal Info -->
      <div class="card">
        <div class="card-header-row">
          <div class="card-title-group">
            <div class="card-icon"><i class="fas fa-user"></i></div>
            <span class="card-title">Personal Info</span>
          </div>
          <a href="#" class="card-action-link" data-bs-toggle="modal" data-bs-target="#editModal">
            Edit <i class="fas fa-arrow-right" style="font-size:0.7rem;"></i>
          </a>
        </div>

        <div class="info-row">
          <span class="info-label">Full Name</span>
          <span class="info-value"><%= user.name %></span>
        </div>
        <div class="info-row">
          <span class="info-label">Email</span>
          <span class="info-value"><%= user.email %></span>
        </div>
        <div class="info-row">
          <span class="info-label">Phone</span>
          <span class="info-value"><%= user.phone || '— Not set —' %></span>
        </div>
        <div class="info-row">
          <span class="info-label">Password</span>
          <span class="info-value password">••••••••••</span>
        </div>
      </div>

      <!-- ══ Delivery Addresses ══ -->
      <div class="card card-full">
        <div class="card-header-row">
          <div class="card-title-group">
            <div class="card-icon"><i class="fas fa-map-marker-alt"></i></div>
            <span class="card-title">Delivery Addresses</span>
          </div>
          <a href="/addAddress" class="addr-add-btn">
            <i class="fas fa-plus"></i> Add Address
          </a>
        </div>

        <% if (userAddress && userAddress.length > 0) { %>
          <div class="addr-grid">
            <% userAddress.forEach(addr => { %>
              <div class="addr-card <%= addr.isDefault ? 'addr-card--default' : '' %>">

                <!-- Top: type pill + default badge -->
                <div class="addr-card__top">
                  <div class="addr-type-pill">
                    <i class="fas <%= addr.addressType === 'Work' ? 'fa-briefcase' : 'fa-home' %>"></i>
                    <%= addr.addressType || 'Home' %>
                  </div>
                  <% if (addr.isDefault) { %>
                    <div class="addr-default-chip">
                      <i class="fas fa-check-circle"></i> Default
                    </div>
                  <% } %>
                </div>

                <!-- Body -->
                <div class="addr-card__body">
                  <p class="addr-name"><%= addr.name %></p>
                  <p class="addr-line">
                    <%= addr.city %>, <%= addr.state %> &mdash; <strong><%= addr.pincode %></strong>
                  </p>
                  <% if (addr.landMark) { %>
                    <p class="addr-landmark">
                      <i class="fas fa-map-pin"></i> <%= addr.landMark %>
                    </p>
                  <% } %>
                  <p class="addr-phone">
                    <i class="fas fa-phone"></i> <%= addr.phone %>
                    <% if (addr.altPhone) { %>
                      &nbsp;&middot;&nbsp;<%= addr.altPhone %>
                    <% } %>
                  </p>
                </div>

                <!-- Actions -->
                <div class="addr-card__actions">
                  <a href="/editAddress/<%= addr._id %>" class="addr-btn addr-btn--edit">
                    <i class="fas fa-pen"></i> Edit
                  </a>
                  <a href="/deleteAddress/<%= addr._id %>"
                     class="addr-btn addr-btn--delete"
                     onclick=" confirmDelete(event, '<%= addr._id %>');">
                    <i class="fas fa-trash-alt"></i> Delete
                  </a>
                </div>

              </div>
            <% }) %>
          </div>

        <% } else { %>
          <div class="addr-empty">
            <div class="addr-empty__icon">
              <i class="fas fa-map-marker-alt"></i>
            </div>
            <p class="addr-empty__title">No addresses saved yet</p>
            <p class="addr-empty__sub">Add a delivery address to make checkout faster</p>
            <a href="/addAddress" class="addr-add-btn addr-add-btn--lg">
              <i class="fas fa-plus"></i> Add New Address
            </a>
          </div>
        <% } %>
      </div>

      <!-- Orders -->
      <div class="card card-full">
        <div class="card-header-row">
          <div class="card-title-group">
            <div class="card-icon"><i class="fas fa-shopping-bag"></i></div>
            <span class="card-title">Recent Orders</span>
          </div>
          <a href="/orders" class="card-action-link">
            View all <i class="fas fa-arrow-right" style="font-size:0.7rem;"></i>
          </a>
        </div>

        <div class="table-responsive">
          <table class="orders-table">
            <thead>
              <tr>
                <th>Order ID</th>
                <th>Date</th>
                <th>Items</th>
                <th>Status</th>
                <th>Total</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td colspan="6" style="text-align:center; padding:40px; color:var(--muted);">
                  <i class="fas fa-shopping-bag" style="font-size:2rem; color:var(--rose-blush); display:block; margin-bottom:12px;"></i>
                  No orders yet. Start shopping!
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

    </div>

    <!-- ── Action Buttons ── -->
    <div class="action-strip">
      <a href="/edit-profile" class="btn-rose" data-bs-toggle="modal" data-bs-target="#editModal">
        <i class="fas fa-pen"></i> Edit Profile
      </a>
      <a href="/change-password" class="btn-ghost" data-bs-toggle="modal" data-bs-target="#passwordModal">
        <i class="fas fa-lock"></i> Change Password
      </a>
    </div>

  </div>
</div>


<script>
  document.getElementById('photoUpload').addEventListener('change', async function (e) {
    const file = e.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = ev => {
      document.getElementById('currentPhoto').src = ev.target.result;
    };
    reader.readAsDataURL(file);

    const formData = new FormData();
    formData.append("image", file);

    try {
      const response = await fetch("/edit-profileImage", {
        method: "POST",
        body: formData
      });
      const data = await response.json();
      if (data.success) {
        Swal.fire({ icon: "success", title: "Profile photo updated successfully" });
      }
    } catch (error) {
      console.log("Upload error:", error);
    }
  });

  const params = new URLSearchParams(window.location.search);
  if (params.get("success")) {
    Swal.fire({ icon: "success", title: "Profile Updated Successfully", showConfirmButton: false, timer: 2000 });
  }
  if (params.get("passsuccess")) {
    Swal.fire({ icon: "success", title: "Password Updated Successfully", showConfirmButton: false, timer: 2000 });
  }
  if (params.get("success")) {
    Swal.fire({ icon: "success", title: "Address added Successfully", showConfirmButton: false, timer: 2000 });
  }
  if (params.get("updatesuccess")) {
    Swal.fire({ icon: "success", title: "Address updated Successfully", showConfirmButton: false, timer: 2000 });
  }
  if (params.get("deletesuccess")) {
    Swal.fire({ icon: "success", title: "Address deleted Successfully", showConfirmButton: false, timer: 2000 });
  }


  function confirmDelete(event, id) {

    event.preventDefault();

    Swal.fire({
      title: "Delete this address?",
      text: "This action cannot be undone.",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#d33",
      cancelButtonColor: "#6c757d",
      confirmButtonText: "Yes, delete it!"
    }).then((result) => {

      if (result.isConfirmed) {
        window.location.href = "/deleteAddress/" + id;
      }

    });

  }

  
</script>
