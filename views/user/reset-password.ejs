<%- include("../../views/partials/user/header") %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: #f9f9f9;
        height: 100vh;
        overflow: hidden;
    }

    main {
        height: calc(100vh - 80px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 15px;
    }

    .login-container {
        display: flex;
        width: 900px;
        height: 100%;
        max-height: 100%;
        max-width: 95vw;
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0,0,0,0.15);
    }

    .login-image {
        flex: 1;
        background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.4)),
                    url('https://images.unsplash.com/photo-1483985988355-763728e1935b?w=800&q=80') center/cover no-repeat;
        display: flex;
        align-items: flex-end;
        padding: 30px;
        color: #fff;
    }

    .login-form-container {
        flex: 1;
        padding: 30px 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background: #fff;
    }

    .icon-wrap {
        text-align: center;
        margin-bottom: 16px;
    }

    .icon-wrap i {
        font-size: 42px;
        color: #d4145a;
        opacity: 0.85;
    }

    .login-form-container h1 {
        font-size: 30px;
        color: #333;
        margin-bottom: 8px;
        text-align: center;
    }

    .helper-text {
        text-align: center;
        color: #888;
        font-size: 13px;
        margin-bottom: 24px;
        line-height: 1.6;
    }

    .form-group {
        margin-bottom: 22px;
        position: relative;
    }

    /* Floating label input */
    .form-group input {
        width: 100%;
        padding: 12px 42px 12px 14px;
        border: 1.5px solid #ddd;
        border-radius: 10px;
        font-size: 15px;
        transition: all 0.3s;
        background: #fff;
    }

    .form-group input:focus {
        outline: none;
        border-color: #d4145a;
        box-shadow: 0 0 0 3px rgba(212, 20, 90, 0.1);
    }

    .form-group label {
        position: absolute;
        left: 16px;
        top: 13px;
        font-size: 15px;
        color: #999;
        pointer-events: none;
        transition: all 0.3s;
        padding: 0 4px;
        background: #fff;
    }

    .form-group input:focus ~ label,
    .form-group input:valid ~ label {
        top: -10px;
        font-size: 12px;
        color: #d4145a;
        font-weight: 600;
    }

    /* Toggle password eye icon */
    .toggle-eye {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: #ccc;
        font-size: 15px;
        transition: color 0.2s;
    }

    .toggle-eye:hover { color: #d4145a; }

    .error-msg {
        color: red;
        font-size: 11px;
        margin-top: 5px;
        min-height: 14px;
    }

    /* Password strength bar */
    .strength-bar-wrap {
        margin-top: 8px;
        height: 4px;
        background: #eee;
        border-radius: 4px;
        overflow: hidden;
    }

    .strength-bar {
        height: 100%;
        width: 0%;
        border-radius: 4px;
        transition: width 0.3s, background 0.3s;
    }

    .strength-label {
        font-size: 11px;
        color: #aaa;
        margin-top: 4px;
        text-align: right;
    }

    .submit-btn {
        width: 100%;
        padding: 13px;
        background: #d4145a;
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
        margin-bottom: 18px;
    }

    .submit-btn:hover {
        background: #b8124a;
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(212, 20, 90, 0.3);
    }

    .alert-danger {
        background: #fff0f3;
        border: 1px solid #f5c2cc;
        color: #b8124a;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 13px;
        text-align: center;
        margin-bottom: 14px;
    }

    .back-link {
        text-align: center;
        font-size: 14px;
        color: #666;
    }

    .back-link a {
        color: #d4145a;
        font-weight: 600;
        text-decoration: none;
    }

    .back-link a:hover { text-decoration: underline; }

    @media (max-width: 900px) {
        .login-container { flex-direction: column; }
        .login-image { min-height: 200px; padding: 25px; }
        .login-form-container { padding: 30px 25px; }
    }

    @media (max-width: 500px) {
        main { padding: 10px; }
        .login-form-container { padding: 25px 20px; }
        .login-image { min-height: 180px; }
        .login-form-container h1 { font-size: 26px; }
    }
</style>

<main>
    <div class="login-container">

        <!-- Left: Fashion Image -->
        <div class="login-image"></div>

        <!-- Right: Change Password Form -->
        <div class="login-form-container">

            <div class="icon-wrap">
                <i class="fas fa-key"></i>
            </div>

            <h1>Change Password</h1>
            <p class="helper-text">
                Choose a strong new password<br>to keep your account secure.
            </p>

            <% if (locals.message && message.length > 0) { %>
                <div class="alert-danger"><%= message %></div>
            <% } %>

            <form id="changePassForm" action="/reset-password" method="POST" onsubmit="return validateForm()">

                <!-- New Password -->
                <div class="form-group">
                    <input type="password" name="newPass1" id="newPass1" >
                    <label>New Password</label>
                    <i class="fas fa-eye toggle-eye" onclick="toggleVisibility('newPass1', this)"></i>
                    <div class="strength-bar-wrap">
                        <div class="strength-bar" id="strengthBar"></div>
                    </div>
                    <div class="strength-label" id="strengthLabel"></div>
                    <div class="error-msg" id="newPass1Error"></div>
                </div>

                <!-- Confirm Password -->
                <div class="form-group">
                    <input type="password" name="newPass2" id="newPass2" >
                    <label>Re-enter New Password</label>
                    <i class="fas fa-eye toggle-eye" onclick="toggleVisibility('newPass2', this)"></i>
                    <div class="error-msg" id="newPass2Error"></div>
                </div>

                <button type="submit" class="submit-btn">
                    <i class="fas fa-lock" style="margin-right:8px;"></i>Update Password
                </button>
            </form>

            <div class="back-link">
                Don't have an account? <a href="/signup">Sign up</a>
            </div>

        </div>
    </div>
</main>

<script>
    // Toggle password visibility
    function toggleVisibility(fieldId, icon) {
        const input = document.getElementById(fieldId);
        const isPassword = input.type === 'password';
        input.type = isPassword ? 'text' : 'password';
        icon.classList.toggle('fa-eye', !isPassword);
        icon.classList.toggle('fa-eye-slash', isPassword);
    }

    // Password strength indicator
    document.getElementById('newPass1').addEventListener('input', function () {
        const val = this.value;
        const bar = document.getElementById('strengthBar');
        const label = document.getElementById('strengthLabel');
        let strength = 0;

        if (val.length >= 6) strength++;
        if (/[A-Z]/.test(val)) strength++;
        if (/[0-9]/.test(val)) strength++;
        if (/[^A-Za-z0-9]/.test(val)) strength++;

        const levels = [
            { width: '0%',   color: '#eee',     text: '' },
            { width: '30%',  color: '#e74c3c',  text: 'Weak' },
            { width: '60%',  color: '#f39c12',  text: 'Fair' },
            { width: '80%',  color: '#2ecc71',  text: 'Good' },
            { width: '100%', color: '#27ae60',  text: 'Strong' },
        ];

        bar.style.width = levels[strength].width;
        bar.style.background = levels[strength].color;
        label.textContent = levels[strength].text;
        label.style.color = levels[strength].color;
    });

    // Form validation
    function validateForm() {
        let valid = true;
        const newPass1 = document.getElementById('newPass1');
        const newPass2 = document.getElementById('newPass2');
        const newPass1Error = document.getElementById('newPass1Error');
        const newPass2Error = document.getElementById('newPass2Error');

        newPass1Error.textContent = '';
        newPass2Error.textContent = '';
        newPass1.style.borderColor = '';
        newPass2.style.borderColor = '';

        if (!newPass1.value.trim()) {
            newPass1Error.textContent = 'Password cannot be empty.';
            newPass1.style.borderColor = 'red';
            valid = false;
        } else if (newPass1.value.length < 6) {
            newPass1Error.textContent = 'Password must be at least 6 characters.';
            newPass1.style.borderColor = 'red';
            valid = false;
        }

        if (!newPass2.value.trim()) {
            newPass2Error.textContent = 'Please re-enter your password.';
            newPass2.style.borderColor = 'red';
            valid = false;
        } else if (newPass2.value !== newPass1.value) {
            newPass2Error.textContent = 'Passwords do not match.';
            newPass2.style.borderColor = 'red';
            valid = false;
        }

        return valid;
    }

</script>

<%- include("../../views/partials/user/footer") %>
