<%- include("../../views/partials/user/header") %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: #f9f9f9;
        height: 100vh;
        overflow: hidden;
    }

    main {
        height: calc(100vh - 80px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 15px;
    }

    .login-container {
        display: flex;
        width: 900px;
        height: 100%;
        max-height: 100%;
        max-width: 95vw;
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0,0,0,0.15);
    }

    /* Left Side - Fashion Image */
    .login-image {
        flex: 1;
        background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.4)),
                    url('https://images.unsplash.com/photo-1483985988355-763728e1935b?w=800&q=80') center/cover no-repeat;
        position: relative;
        display: flex;
        align-items: flex-end;
        padding: 30px;
        color: #fff;
    }

    /* Right Side - Form */
    .login-form-container {
        flex: 1;
        padding: 30px 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background: #fff;
    }

    .login-form-container h1 {
        font-size: 32px;
        color: #333;
        margin-bottom: 8px;
        text-align: center;
    }

    .login-form-container > p {
        text-align: center;
        color: #777;
        margin-bottom: 25px;
        font-size: 14px;
    }

    .form-group {
        margin-bottom: 18px;
        position: relative;
    }

    .form-group input {
        width: 100%;
        padding: 12px 14px;
        border: 1.5px solid #ddd;
        border-radius: 10px;
        font-size: 15px;
        transition: all 0.3s;
    }

    .form-group input:focus {
        outline: none;
        border-color: #d4145a;
        box-shadow: 0 0 0 3px rgba(212, 20, 90, 0.1);
    }

    .form-group label {
        position: absolute;
        left: 16px;
        top: 13px;
        font-size: 15px;
        color: #999;
        pointer-events: none;
        transition: all 0.3s;
        padding: 0 6px;
    }

    .form-group input:focus ~ label,
    .form-group input:valid ~ label {
        top: -10px;
        font-size: 12px;
        color: #d4145a;
        font-weight: 600;
    }

    /* Icon inside input */
    .input-icon {
        position: relative;
    }

    .input-icon i {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #ccc;
        font-size: 16px;
        pointer-events: none;
    }

    /* Helper text */
    .helper-text {
        text-align: center;
        color: #888;
        font-size: 13px;
        margin-bottom: 22px;
        line-height: 1.6;
    }

    /* Submit Button */
    .submit-btn {
        width: 100%;
        padding: 13px;
        background: #d4145a;
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
        margin-bottom: 18px;
    }

    .submit-btn:hover {
        background: #b8124a;
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(212, 20, 90, 0.3);
    }

    .error-msg {
        color: red;
        font-size: 10px;
        margin-top: 4px;
    }

    .back-link {
        text-align: center;
        font-size: 14px;
        color: #666;
        margin-top: 0px;
        margin-bottom: 10px;
    }

    .back-link a {
        color: #d4145a;
        font-weight: 600;
        text-decoration: none;
    }

    .back-link a:hover {
        text-decoration: underline;
    }

    /* Lock icon illustration */
    .lock-icon-wrap {
        text-align: center;
        margin-bottom: 20px;
    }

    .lock-icon-wrap i {
        font-size: 42px;
        color: #d4145a;
        opacity: 0.85;
    }

    /* Responsive */
    @media (max-width: 900px) {
        .login-container { flex-direction: column; }
        .login-image { min-height: 200px; padding: 25px; }
        .login-form-container { padding: 30px 25px; }
    }

    @media (max-width: 500px) {
        main { padding: 10px; }
        .login-form-container { padding: 25px 20px; }
        .login-image { min-height: 180px; }
        .login-form-container h1 { font-size: 28px; }
    }
</style>

<main>
    <div class="login-container">

        <!-- Left: Fashion Image -->
        <div class="login-image"></div>

        <!-- Right: Forgot Password Form -->
        <div class="login-form-container">

            <div class="lock-icon-wrap">
                <i class="fas fa-lock"></i>
            </div>

            <h1>Forgot Password?</h1>

            <p class="helper-text">
                No worries! Enter your email and we'll<br>send you a reset link.
            </p>

            <form id="forgotForm" action="/forgot-email-valid" method="POST" onsubmit="return validateForgotForm()">
                <div class="form-group input-icon">
                    <input type="text" name="email" id="emailInput" >
                    <label>Email Address</label>
                    <i class="fas fa-envelope"></i>
                    <div class="error-msg" id="emailError"></div>
                </div>

                <button type="submit" class="submit-btn">
                    <i class="fas fa-paper-plane" style="margin-right:8px;"></i>Send Reset Link
                </button>
            </form>

            <div class="back-link">
                Remember your password? <a href="/login">Back to Login</a>
            </div>

            <div class="back-link" style="margin-top:6px;">
                Don't have an account? <a href="/signup">Sign up</a>
            </div>

        </div>
    </div>
</main>

<script>
    function validateForgotForm() {
        const emailInput = document.getElementById('emailInput');
        const emailError = document.getElementById('emailError');
        const emailValue = emailInput.value.trim();
        const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

        emailError.textContent = '';
        emailInput.style.borderColor = '';

        if (emailValue === '') {
            emailError.textContent = 'Email is required.';
            emailInput.style.borderColor = 'red';
            return false;
        } else if (!emailPattern.test(emailValue)) {
            emailError.textContent = 'Please enter a valid email address.';
            emailInput.style.borderColor = 'red';
            return false;
        }

        return true;
    }
</script>

<%- include("../../views/partials/user/footer") %>
