<%- include("../../views/partials/admin/header") %>

<style>
    :root {
        --primary: #d4145a;
        --primary-dark: #a81049;
        --primary-light: rgba(212,20,90,0.08);
        --success: #28a745;
        --danger: #dc3545;
        --text-muted: #888;
        --border: #eee;
        --bg: #f5f5f5;
        --transition: all 0.3s ease;
        --card-shadow: 0 4px 20px rgba(0,0,0,0.08);
    }
    body { background: var(--bg); font-family: 'Nunito Sans', sans-serif; color:#333; }
    .content-main { padding:32px 30px; }
    .card { background:white; border-radius:14px; box-shadow: var(--card-shadow); margin-bottom:28px; }
    .card-header { background:#fafafa; padding:18px 24px; font-size:15px; font-weight:700; display:flex; align-items:center; gap:10px; }
    .card-body { padding:26px; }
    .form-grid-2, .form-grid-3 { display:grid; gap:18px; }
    .form-grid-2 { grid-template-columns:1fr 1fr; }
    .form-grid-3 { grid-template-columns:1fr 1fr 1fr; }
    .form-group { margin-bottom:0; }
    .form-label { font-weight:700; font-size:12.5px; margin-bottom:7px; display:block; text-transform:uppercase; letter-spacing:0.4px; }
    .form-control { border:1.5px solid #e0e0e0; border-radius:9px; padding:11px 14px; font-size:14px; width:100%; transition:var(--transition); background:#fff; color:#333; font-family:'Nunito Sans',sans-serif; }
    .form-control:focus { border-color:var(--primary); box-shadow:0 0 0 3px rgba(212,20,90,0.1); outline:none; }
    .form-control.invalid { border-color:var(--danger); box-shadow:0 0 0 3px rgba(220,53,69,0.1); }
    .form-control.valid { border-color:var(--success); box-shadow:0 0 0 3px rgba(40,167,69,0.08); }
    .btn-publish { background:linear-gradient(135deg,var(--primary),var(--primary-dark)); color:white; padding:13px 36px; border-radius:50px; font-weight:700; border:none; cursor:pointer; transition:var(--transition); box-shadow:0 4px 14px rgba(212,20,90,0.3); display:inline-flex; align-items:center; gap:8px; }
    .btn-publish:hover { transform:translateY(-2px); box-shadow:0 8px 22px rgba(212,20,90,0.35); }
    .alert { padding:13px 18px; border-radius:9px; margin-bottom:20px; font-size:14px; font-weight:600; }
    .alert-success { background:rgba(40,167,69,0.1); color:var(--success); border-left:4px solid var(--success); }
    .alert-error { background:rgba(220,53,69,0.08); color:var(--danger); border-left:4px solid var(--danger); }
    .error-msg { color:var(--danger); font-size:12px; margin-top:5px; display:none; align-items:center; gap:4px; font-weight:600; }
    .error-msg.visible { display:flex; }
    .field-hint { font-size:11.5px; color:var(--text-muted); margin-top:5px; }
    .actions-cell { display:flex; gap:6px; align-items:center; }
    .btn-edit { background:rgba(40,167,69,0.08); color:var(--success); border:none; padding:7px 13px; border-radius:7px; font-size:12px; font-weight:700; cursor:pointer; transition:var(--transition); text-decoration:none; display:inline-flex; align-items:center; gap:5px; }
    .btn-edit:hover { background:var(--success); color:white; }
</style>

<section class="content-main">
    <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success">✓ <%= success %></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error">⚠ <%= error %></div>
    <% } %>

    <div class="card">
        <div class="card-header">
            <div class="header-icon">✏️</div>
            Edit Coupon
        </div>
        <div class="card-body">
            <form action="/admin/edit-coupon/<%= coupon._id %>" method="POST" novalidate>
                <div class="form-grid-2" style="margin-bottom:18px;">
                    <div class="form-group">
                        <label class="form-label">Coupon Code <span class="required">*</span></label>
                        <input type="text" name="code" class="form-control" value="<%= coupon.code %>" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Discount Type <span class="required">*</span></label>
                        <select name="type" class="form-control">
                            <option value="flat" <%= coupon.type === 'flat' ? 'selected' : '' %>>₹ Flat</option>
                            <option value="percentage" <%= coupon.type === 'percentage' ? 'selected' : '' %>>% Percentage</option>
                        </select>
                    </div>
                </div>
                <div class="form-grid-3" style="margin-bottom:18px;">
                    <div class="form-group">
                        <label class="form-label">Discount <span class="required">*</span></label>
                        <input type="number" name="discount" class="form-control" value="<%= coupon.discount %>" min="0" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Min Order Amount <span class="optional">(optional)</span></label>
                        <input type="number" name="minAmount" class="form-control" value="<%= coupon.minAmount %>" min="0">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Expiry Date <span class="required">*</span></label>
                        <input type="date" name="expiry" class="form-control" value="<%= coupon.expiry.toISOString().split('T')[0] %>" required>
                    </div>
                </div>
                <div class="form-grid-3" style="margin-bottom:22px;">
                    <div class="form-group">
                        <label class="form-label">Usage Limit <span class="required">*</span></label>
                        <input type="number" name="usageLimit" class="form-control" value="<%= coupon.usageLimit %>" min="1" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Per User Limit <span class="required">*</span></label>
                        <input type="number" name="perUserLimit" class="form-control" value="<%= coupon.perUserLimit %>" min="1" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Status</label>
                        <select name="isActive" class="form-control">
                            <option value="true" <%= coupon.isActive ? 'selected' : '' %>>✅ Active</option>
                            <option value="false" <%= !coupon.isActive ? 'selected' : '' %>>⏸ Inactive</option>
                        </select>
                    </div>
                </div>
<button type="submit" class="btn-publish">💾 Save Changes</button>
<a href="/admin/coupon" class="btn-publish" style="margin-left:8px;">Back to Coupons</a>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // Simple client‑side validation mirroring the create form (optional)
    const form = document.querySelector('form');
    form.addEventListener('submit', e => {
        // custom validation if needed
    });

    // Show success SweetAlert if success message is present
    <% if (typeof success !== 'undefined' && success) { %>
    Swal.fire({
        icon: 'success',
        title: 'Success',
        text: '<%= success %>',
        confirmButtonColor: '#d4145a',
        confirmButtonText: 'Back to Coupons'
    }).then(() => {
        window.location.href = '/admin/coupon';
    });
    <% } %>
</script>
            </form>
        </div>
    </div>
</section>

