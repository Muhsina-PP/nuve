<%- include("../../views/partials/user/header") %>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
  .cp-page {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 16px;
    background: #fdfbfc;
  }

  .cp-card {
    width: 100%;
    max-width: 460px;
    background: white;
    border-radius: 20px;
    box-shadow: 0 8px 32px rgba(212,20,90,0.10);
    overflow: hidden;
    border: 1px solid #eedde5;
  }

  /* Header */
  .cp-card-header {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 24px 32px;
    background: linear-gradient(135deg, #d4145a 0%, #9e0f44 100%);
  }

  .cp-card-icon {
    width: 42px; height: 42px;
    border-radius: 12px;
    background: rgba(255,255,255,0.18);
    display: flex; align-items: center; justify-content: center;
    color: white;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .cp-card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    font-weight: 600;
    color: white;
    margin: 0;
    line-height: 1.2;
  }

  .cp-card-subtitle {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.65);
    margin: 3px 0 0;
    font-family: 'DM Sans', sans-serif;
  }

  /* Body */
  .cp-card-body {
    padding: 32px;
    font-family: 'DM Sans', sans-serif;
  }

  .cp-field { margin-bottom: 18px; }

  .cp-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #8a8aa0;
    margin-bottom: 7px;
  }

  .cp-input-wrap { position: relative; }

  .cp-input-icon {
    position: absolute;
    left: 14px; top: 50%;
    transform: translateY(-50%);
    color: #d4145a;
    font-size: 0.8rem;
    pointer-events: none;
  }

  .cp-input {
    width: 100%;
    padding: 11px 42px 11px 38px;
    border: 1.5px solid #eedde5;
    border-radius: 12px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.92rem;
    color: #1a1a2e;
    background: #fdfbfc;
    outline: none;
    transition: all 0.2s;
  }

  .cp-input:focus {
    border-color: #d4145a;
    background: white;
    box-shadow: 0 0 0 3px rgba(212,20,90,0.10);
  }

  .cp-eye {
    position: absolute;
    right: 12px; top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: #c0aab3;
    cursor: pointer;
    font-size: 0.85rem;
    padding: 4px;
    transition: color 0.2s;
  }

  .cp-eye:hover { color: #d4145a; }

  /* Divider */
  .cp-divider {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 4px 0 18px;
    color: #c0aab3;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
  }

  .cp-divider::before, .cp-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #eedde5;
  }

  /* Strength bar */
  .cp-strength-bar {
    height: 4px;
    background: #f0e6eb;
    border-radius: 4px;
    margin-top: 8px;
    overflow: hidden;
  }

  .cp-strength-fill {
    height: 100%;
    width: 0%;
    border-radius: 4px;
    transition: all 0.4s ease;
  }

  .cp-strength-label {
    font-size: 0.75rem;
    font-weight: 600;
    margin-top: 5px;
    display: block;
  }

  /* Match message */
  .cp-match-msg {
    font-size: 0.78rem;
    margin-top: 5px;
    display: block;
    font-weight: 500;
  }

  /* Hints */
  .cp-hints {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 16px;
    padding: 0;
    margin: 0 0 24px;
  }

  .cp-hints li {
    font-size: 0.78rem;
    color: #c0aab3;
    display: flex;
    align-items: center;
    gap: 5px;
    transition: color 0.3s;
  }

  .cp-hints li i { font-size: 0.5rem; }

  .cp-hints li.cp-hint-ok { color: #1a7a46; }
  .cp-hints li.cp-hint-ok i { color: #1a7a46; }

  /* Footer */
  .cp-footer {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
  }

  .cp-btn-cancel {
    padding: 11px 24px;
    border-radius: 50px;
    border: 1.5px solid #eedde5;
    background: white;
    color: #8a8aa0;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 0.88rem;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s;
    display: inline-flex; align-items: center; gap: 6px;
  }

  .cp-btn-cancel:hover { border-color: #d4145a; color: #d4145a; }

  .cp-btn-save {
    padding: 11px 28px;
    border-radius: 50px;
    border: none;
    background: linear-gradient(135deg, #d4145a 0%, #9e0f44 100%);
    color: white;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 0.88rem;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(212,20,90,0.28);
    transition: all 0.2s;
    display: inline-flex; align-items: center; gap: 7px;
    opacity: 0.5;
    pointer-events: none;
  }

  .cp-btn-save.cp-ready {
    opacity: 1;
    pointer-events: auto;
  }

  .cp-btn-save.cp-ready:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(212,20,90,0.38);
  }
</style>

<div class="cp-page">
  <div class="cp-card">

    <div class="cp-card-header">
      <div class="cp-card-icon"><i class="fas fa-lock"></i></div>
      <div>
        <h4 class="cp-card-title">Change Password</h4>
        <p class="cp-card-subtitle">Keep your account secure</p>
      </div>
    </div>

    <div class="cp-card-body">
      <form id="changePasswordForm" action="/change-password" method="POST">

        <!-- Current password -->
        <div class="cp-field">
          <label class="cp-label" for="cpCurrent">Current Password</label>
          <div class="cp-input-wrap">
            <i class="fas fa-lock cp-input-icon"></i>
            <input type="password" id="cpCurrent" name="currentPassword"
                   class="cp-input" placeholder="Enter current password" required>
            <button type="button" class="cp-eye" data-target="cpCurrent">
              <i class="fas fa-eye"></i>
            </button>
          </div>
        </div>

        <div class="cp-divider"><span>Set new password</span></div>

        <!-- New password -->
        <div class="cp-field">
          <label class="cp-label" for="cpNew">New Password</label>
          <div class="cp-input-wrap">
            <i class="fas fa-key cp-input-icon"></i>
            <input type="password" id="cpNew" name="newPassword"
                   class="cp-input" placeholder="Min. 8 characters"
                   minlength="8" required oninput="cpCheckStrength(this.value)">
            <button type="button" class="cp-eye" data-target="cpNew">
              <i class="fas fa-eye"></i>
            </button>
          </div>
          <div class="cp-strength-bar">
            <div class="cp-strength-fill" id="cpStrengthFill"></div>
          </div>
          <span class="cp-strength-label" id="cpStrengthLabel"></span>
        </div>

        <!-- Confirm password -->
        <div class="cp-field">
          <label class="cp-label" for="cpConfirm">Confirm New Password</label>
          <div class="cp-input-wrap">
            <i class="fas fa-shield-halved cp-input-icon"></i>
            <input type="password" id="cpConfirm" name="confirmPassword"
                   class="cp-input" placeholder="Re-enter new password"
                   required oninput="cpCheckMatch()">
            <button type="button" class="cp-eye" data-target="cpConfirm">
              <i class="fas fa-eye"></i>
            </button>
          </div>
          <span class="cp-match-msg" id="cpMatchMsg"></span>
        </div>

        <!-- Hints -->
        <ul class="cp-hints">
          <li id="hint-len"><i class="fas fa-circle-dot"></i> At least 8 characters</li>
          <li id="hint-upper"><i class="fas fa-circle-dot"></i> One uppercase letter</li>
          <li id="hint-num"><i class="fas fa-circle-dot"></i> One number</li>
        </ul>

        <div class="cp-footer">
          <a href="/userProfile" class="cp-btn-cancel">
            <i class="fas fa-arrow-left"></i> Cancel
          </a>
          <button type="submit" class="cp-btn-save" id="cpSubmitBtn">
            <i class="fas fa-check"></i> Update Password
          </button>
        </div>

      </form>
    </div>

  </div>
</div>

<script>
  /* Eye toggle */
  document.querySelectorAll('.cp-eye').forEach(btn => {
    btn.addEventListener('click', () => {
      const inp = document.getElementById(btn.dataset.target);
      const isText = inp.type === 'text';
      inp.type = isText ? 'password' : 'text';
      btn.querySelector('i').className = isText ? 'fas fa-eye' : 'fas fa-eye-slash';
    });
  });

  /* Strength check */
  function cpCheckStrength(val) {
    const fill   = document.getElementById('cpStrengthFill');
    const label  = document.getElementById('cpStrengthLabel');
    const hasLen   = val.length >= 8;
    const hasUpper = /[A-Z]/.test(val);
    const hasNum   = /[0-9]/.test(val);

    document.getElementById('hint-len').classList.toggle('cp-hint-ok', hasLen);
    document.getElementById('hint-upper').classList.toggle('cp-hint-ok', hasUpper);
    document.getElementById('hint-num').classList.toggle('cp-hint-ok', hasNum);

    const score = [hasLen, hasUpper, hasNum].filter(Boolean).length;
    const map = [
      { w: '0%',   color: 'transparent', text: '' },
      { w: '33%',  color: '#e74c3c',     text: 'Weak' },
      { w: '66%',  color: '#f59e0b',     text: 'Fair' },
      { w: '100%', color: '#1a7a46',     text: 'Strong' },
    ];
    fill.style.width      = map[score].w;
    fill.style.background = map[score].color;
    label.textContent     = map[score].text;
    label.style.color     = map[score].color;

    cpCheckMatch();
  }

  /* Match check */
  function cpCheckMatch() {
    const newVal  = document.getElementById('cpNew').value;
    const confVal = document.getElementById('cpConfirm').value;
    const msg     = document.getElementById('cpMatchMsg');
    const btn     = document.getElementById('cpSubmitBtn');

    if (!confVal) { msg.textContent = ''; return; }

    const ok = newVal === confVal && newVal.length >= 8;
    msg.textContent = ok ? '✓ Passwords match' : '✗ Passwords do not match';
    msg.style.color = ok ? '#1a7a46' : '#e74c3c';
    btn.classList.toggle('cp-ready', ok);
  }
</script>
