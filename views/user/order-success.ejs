<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Placed Successfully</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', sans-serif; background: #f4f4f4; }

    .success-page {
      min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      padding: 40px 5%;
    }

    .success-wrap { max-width: 600px; width: 100%; }

    /* ── Main Card ── */
    .success-card {
      background: #fff; border-radius: 16px;
      border: 1px solid #f0f0f0;
      padding: 48px 40px 36px;
      text-align: center; margin-bottom: 20px;
      position: relative; overflow: hidden;
    }

    .success-card::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 5px;
      background: linear-gradient(90deg, #d4145a, #ff6b9d, #d4145a, #ff6b9d);
      background-size: 200% 100%;
      animation: shimmer 2.5s linear infinite;
    }
    @keyframes shimmer {
      0%   { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }

    /* ── SVG Illustration ── */
    .success-illustration {
      width: 120px; height: 120px;
      margin: 0 auto 24px; position: relative;
    }
    .success-illustration svg { width: 100%; height: 100%; }

    .check-circle {
      fill: none; stroke: #d4145a; stroke-width: 3;
      stroke-dasharray: 314; stroke-dashoffset: 314;
      animation: drawCircle 0.7s ease forwards 0.2s;
    }
    .check-mark {
      fill: none; stroke: #d4145a; stroke-width: 4;
      stroke-linecap: round; stroke-linejoin: round;
      stroke-dasharray: 60; stroke-dashoffset: 60;
      animation: drawCheck 0.5s ease forwards 0.9s;
    }
    @keyframes drawCircle { to { stroke-dashoffset: 0; } }
    @keyframes drawCheck  { to { stroke-dashoffset: 0; } }

    /* Particles */
    .particle {
      position: absolute; border-radius: 50%;
      opacity: 0; animation: floatUp 1.4s ease forwards;
    }
    .particle:nth-child(1) { width:8px; height:8px; left:20%; top:60%; background:#ff6b9d; animation-delay:0.9s; }
    .particle:nth-child(2) { width:6px; height:6px; left:75%; top:55%; background:#fbb;    animation-delay:1.1s; }
    .particle:nth-child(3) { width:5px; height:5px; left:50%; top:70%; background:#d4145a; animation-delay:1.0s; }
    .particle:nth-child(4) { width:7px; height:7px; left:35%; top:65%; background:#fbeaf0; border:1px solid #d4145a; animation-delay:1.2s; }
    .particle:nth-child(5) { width:5px; height:5px; left:62%; top:68%; background:#ff6b9d; animation-delay:1.15s; }
    @keyframes floatUp {
      0%   { opacity:0; transform: translateY(0) scale(0.5); }
      40%  { opacity:1; }
      100% { opacity:0; transform: translateY(-55px) scale(1); }
    }

    .success-title {
      font-size: 26px; font-weight: 800; color: #222;
      margin-bottom: 10px;
      animation: fadeUp 0.5s ease forwards 1.1s; opacity: 0;
    }
    .success-sub {
      font-size: 14px; color: #888; line-height: 1.6;
      margin-bottom: 28px;
      animation: fadeUp 0.5s ease forwards 1.25s; opacity: 0;
    }
    @keyframes fadeUp {
      from { opacity:0; transform: translateY(10px); }
      to   { opacity:1; transform: translateY(0); }
    }

    .order-id-pill {
      display: inline-flex; align-items: center; gap: 8px;
      background: #fbeaf0; border: 1px solid #f4c0d1;
      border-radius: 50px; padding: 8px 20px;
      font-size: 13px; color: #d4145a; font-weight: 600;
      margin-bottom: 28px;
      animation: fadeUp 0.5s ease forwards 1.35s; opacity: 0;
    }
    .order-id-pill span { color: #222; font-weight: 700; }

    .delivery-banner {
      background: #f9f9f9; border-radius: 10px;
      border: 1px solid #f0f0f0; padding: 14px 20px;
      display: flex; align-items: center; justify-content: center;
      gap: 10px; font-size: 13px; color: #555;
      margin-bottom: 28px;
      animation: fadeUp 0.5s ease forwards 1.45s; opacity: 0;
    }
    .delivery-icon {
      width: 36px; height: 36px; background: #e8f5e9;
      border-radius: 50%; display: flex;
      align-items: center; justify-content: center;
      font-size: 18px; flex-shrink: 0;
    }
    .delivery-text strong { color: #2e7d32; display: block; font-size: 14px; margin-bottom: 1px; }

    .action-btns {
      display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;
      animation: fadeUp 0.5s ease forwards 1.55s; opacity: 0;
    }
    .btn-primary {
      flex: 1; min-width: 160px;
      padding: 13px 24px; background: #d4145a;
      color: #fff; border: none; border-radius: 50px;
      font-size: 14px; font-weight: 700; cursor: pointer;
      text-align: center; text-decoration: none;
      transition: all 0.3s; display: inline-block;
    }
    .btn-primary:hover { background: #a81049; }

    .btn-outline {
      flex: 1; min-width: 160px;
      padding: 13px 24px; background: #fff;
      color: #d4145a; border: 2px solid #f4c0d1;
      border-radius: 50px; font-size: 14px; font-weight: 700;
      cursor: pointer; text-align: center; text-decoration: none;
      transition: all 0.3s; display: inline-block;
    }
    .btn-outline:hover { background: #fbeaf0; border-color: #d4145a; }

    /* ── Mini Summary ── */
    .mini-summary {
      background: #fff; border-radius: 12px;
      border: 1px solid #f0f0f0; padding: 22px 24px;
      animation: fadeUp 0.5s ease forwards 1.65s; opacity: 0;
    }
    .mini-summary-title {
      font-size: 14px; font-weight: 700; color: #222;
      margin-bottom: 14px; padding-bottom: 12px;
      border-bottom: 1px solid #f5f5f5;
    }
    .mini-row {
      display: flex; justify-content: space-between;
      font-size: 13px; color: #666; margin-bottom: 10px;
    }
    .mini-row span:last-child { font-weight: 600; color: #333; }
    .mini-row.total {
      font-size: 15px; font-weight: 700; color: #222;
      padding-top: 10px;
      border-top: 1px dashed #f0f0f0; margin-top: 4px;
    }
    .mini-row.savings { color: #2e7d32; font-size: 12px; }
    .mini-row.savings span:last-child { color: #2e7d32; }

    .payment-badge {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 12px; color: #aaa;
      background: #f9f9f9; border: 1px solid #f0f0f0;
      border-radius: 20px; padding: 5px 14px; margin-top: 6px;
    }

    @media (max-width: 480px) {
      .success-card { padding: 36px 20px 28px; }
      .action-btns { flex-direction: column; }
      .btn-primary, .btn-outline { min-width: unset; width: 100%; }
    }
  </style>
</head>
<body>

<main class="success-page">
  <div class="success-wrap">

    <!-- ── Success Card ── -->
    <div class="success-card">

      <div class="success-illustration">
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>

        <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
          <circle cx="50" cy="50" r="48" fill="#fbeaf0"/>
          <circle class="check-circle" cx="50" cy="50" r="44" transform="rotate(-90 50 50)"/>
          <polyline class="check-mark" points="28,52 43,67 72,35"/>
        </svg>
      </div>

      <div class="success-title">Order Placed Successfully! 🎉</div>
      <div class="success-sub">
        Thank you for shopping with us! Your order has been confirmed<br>
        and will be packed and dispatched shortly.
      </div>

      <div class="order-id-pill">
        🛍️ Order ID: <span><%= orderId %></span>
      </div>

      <div class="delivery-banner">
        <div class="delivery-icon">🚚</div>
        <div class="delivery-text">
          <strong>Estimated Delivery: 3–5 Business Days</strong>
          We'll notify you once your order is shipped
        </div>
      </div>

      <div class="action-btns">
        <a href="/orders" class="btn-primary">
          View Order Details
        </a>
        <a href="/shop" class="btn-outline">
          Continue Shopping
        </a>
      </div>

    </div>

    <!-- ── Mini Price Summary ── -->
     <% if (orderedItems.length > 0) { %>
      <%
        const totalMRP      = orderedItems.reduce((s, i) => s + i.regularPrice * i.quantity, 0);
        const totalSale     = orderedItems.reduce((s, i) => s + i.price    * i.quantity, 0);
        const totalDiscount = totalMRP - totalSale;
        const delivery      = totalSale >= 999 ? 0 : 99;
        const grandTotal    = totalSale + delivery;
      %>
      
    <div class="mini-summary">
      <div class="mini-summary-title">Order Summary</div>

      <div class="mini-row">
        <span>Items Total (MRP)</span>
        <span>₹<%= totalMRP %></span>
      </div>
      <div class="mini-row" style="color:#2e7d32;">
        <span>Product Discount</span>
        <span style="color:#2e7d32;">− ₹<%= totalDiscount %></span>
      </div>
      <!-- Coupon row — show/hide as needed -->
      <div class="mini-row" style="color:#2e7d32; display:none;" id="couponRow">
        <span>Coupon Discount</span>
        <span style="color:#2e7d32;">− ₹0</span>
      </div>
      <!-- Tax row — show/hide as needed -->
      <div class="mini-row" style="display:none;" id="taxRow">
        <span>Tax (GST)</span>
        <span>₹0</span>
      </div>
      <div class="mini-row">
        <span>Delivery</span>
        <span style="color:#2e7d32;"><%= delivery %></span>
      </div>

      <div class="mini-row total">
        <span>Total Paid</span>
        <span>₹<%= grandTotal %></span>
      </div>

      <div class="mini-row savings">
        <span>🎊 You saved</span>
        <span>₹<%= totalDiscount %> on this order!</span>
      </div>

      <div style="text-align:center; margin-top:12px;">
        <span class="payment-badge">💵 Paid via Cash on Delivery</span>
      </div>
    </div>
    <% } %>

  </div>
</main>

</body>
</html>