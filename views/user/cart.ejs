<%- include("../../views/partials/user/header") %>

<style>
  .cart-page { background: #f4f4f4; min-height: 80vh; }

  .breadcrumb-bar { background: #fff; border-bottom: 1px solid #eee; padding: 12px 5%; }
  .breadcrumb { font-size: 13px; color: #aaa; display: flex; gap: 6px; align-items: center; list-style: none; }
  .breadcrumb a { color: #d4145a; text-decoration: none; }
  .breadcrumb span { color: #ddd; }

  .cart-wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 30px 5%;
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 24px;
    align-items: start;
  }

  .cart-heading { font-size: 22px; font-weight: 700; color: #222; margin-bottom: 4px; }
  .cart-sub { font-size: 13px; color: #aaa; margin-bottom: 20px; }

  /* Cart Item Card */
  .cart-item {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #f0f0f0;
    padding: 20px;
    display: flex;
    gap: 20px;
    margin-bottom: 16px;
    transition: box-shadow 0.2s;
  }
  .cart-item:hover { box-shadow: 0 4px 16px rgba(212, 20, 90, 0.08); }

  .item-img {
    width: 110px;
    height: 130px;
    border-radius: 8px;
    object-fit: cover;
    border: 1px solid #f0f0f0;
    flex-shrink: 0;
    background: #fbeaf0;
  }

  .item-details { flex: 1; min-width: 0; }

  .item-name {
    font-size: 15px;
    font-weight: 600;
    color: #222;
    margin-bottom: 4px;
    text-decoration: none;
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .item-name:hover { color: #d4145a; }

  .item-meta { font-size: 12px; color: #aaa; margin-bottom: 10px; }

  .item-price-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }
  .item-sale { font-size: 18px; font-weight: 700; color: #d4145a; }
  .item-orig { font-size: 13px; color: #aaa; text-decoration: line-through; }
  .item-discount {
    font-size: 12px;
    color: #2e7d32;
    font-weight: 600;
    background: #e8f5e9;
    padding: 2px 8px;
    border-radius: 20px;
  }

  .qty-row { display: flex; align-items: center; gap: 12px; }
  .qty-label { font-size: 12px; color: #999; }
  .qty-ctrl {
    display: flex;
    align-items: center;
    border: 1px solid #eee;
    border-radius: 50px;
    overflow: hidden;
  }
  .qty-btn {
    width: 32px;
    height: 32px;
    background: #fff;
    border: none;
    font-size: 16px;
    color: #d4145a;
    cursor: pointer;
    font-weight: 700;
    transition: background 0.2s;
  }
  .qty-btn:hover { background: #fbeaf0; }
  .qty-val {
    width: 36px;
    text-align: center;
    font-size: 14px;
    font-weight: 600;
    color: #222;
    border: none;
    outline: none;
    background: #fff;
  }

  .item-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
    flex-shrink: 0;
  }
  .item-total { font-size: 16px; font-weight: 700; color: #222; text-align: right; }
  .item-total-label { font-size: 11px; color: #aaa; text-align: right; margin-bottom: 2px; }

  .remove-item {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid #eee;
    background: #fff;
    color: #bbb;
    cursor: pointer;
    font-size: 13px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    text-decoration: none;
  }
  .remove-item:hover { background: #d4145a; color: #fff; border-color: #d4145a; }

  /* Order Summary */
  .summary-card {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #f0f0f0;
    padding: 24px;
    position: sticky;
    top: 20px;
  }
  .summary-title {
    font-size: 16px;
    font-weight: 700;
    color: #222;
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 1px solid #f5f5f5;
  }
  .summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
    font-size: 14px;
    color: #555;
  }
  .summary-row span:last-child { font-weight: 600; }
  .summary-row.discount { color: #2e7d32; }
  .summary-row.discount span:last-child { color: #2e7d32; }
  .summary-row.total {
    font-size: 16px;
    font-weight: 700;
    color: #222;
    padding-top: 14px;
    border-top: 2px dashed #f0f0f0;
    margin-top: 4px;
  }

  .coupon-row { display: flex; gap: 8px; margin: 18px 0; }
  .coupon-input {
    flex: 1;
    padding: 10px 14px;
    border: 1px solid #eee;
    border-radius: 50px;
    font-size: 13px;
    outline: none;
    color: #333;
  }
  .coupon-input:focus { border-color: #d4145a; }
  .coupon-btn {
    padding: 10px 18px;
    background: #fbeaf0;
    color: #d4145a;
    border: 1px solid #f4c0d1;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s;
  }
  .coupon-btn:hover { background: #d4145a; color: #fff; border-color: #d4145a; }

  .checkout-btn {
    display: block;
    width: 100%;
    padding: 14px;
    background: #d4145a;
    color: #fff;
    border: none;
    border-radius: 50px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    text-align: center;
    transition: all 0.3s;
    margin-top: 10px;
    text-decoration: none;
  }
  .checkout-btn:hover { background: #a81049; }

  .safe-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-size: 12px;
    color: #aaa;
    margin-top: 14px;
  }

  .continue-link {
    display: block;
    text-align: center;
    margin-top: 12px;
    font-size: 13px;
    color: #d4145a;
    text-decoration: none;
    font-weight: 500;
  }

  /* Empty Cart */
  .empty-cart {
    background: #fff;
    border-radius: 12px;
    border: 1px dashed #f4c0d1;
    text-align: center;
    padding: 80px 20px;
  }
  .empty-icon {
    width: 72px;
    height: 72px;
    background: #fbeaf0;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
    font-size: 28px;
    color: #d4145a;
  }
  .empty-title { font-size: 20px; font-weight: 600; color: #333; margin-bottom: 8px; }
  .empty-sub { font-size: 14px; color: #aaa; margin-bottom: 24px; }
  .shop-btn {
    display: inline-block;
    padding: 12px 32px;
    background: #d4145a;
    color: #fff;
    border-radius: 50px;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    transition: all 0.3s;
  }
  .shop-btn:hover { background: #a81049; }

  @media (max-width: 900px) {
    .cart-wrap { grid-template-columns: 1fr; }
    .summary-card { position: static; }
  }
  @media (max-width: 560px) {
    .cart-item { flex-wrap: wrap; }
    .item-actions { flex-direction: row; width: 100%; justify-content: space-between; }
    .item-img { width: 80px; height: 100px; }
  }
</style>

<main class="cart-page">

  <div class="breadcrumb-bar">
    <div class="breadcrumb">
      <a href="/" rel="nofollow">Home</a>
      <span>&#9656;</span>  <a href="/shop" rel="nofollow">Shop</a>
      <span>&#9656;</span> My Cart
    </div>
  </div>

  <div class="cart-wrap">

    <!-- LEFT: Cart Items -->
    <div class="cart-left">
      <div class="cart-heading">My Cart</div>
      <div class="cart-sub"><%= cartItems.length %> item<%= cartItems.length !== 1 ? 's' : '' %> in your bag</div>

      <% if (cartItems.length > 0) { %>

        <% cartItems.forEach(item => { %>

          <%
            const salePrice   = item.productId.salePrice;
            const regularPrice = item.productId.regularPrice;
            const quantity         = item.quantity;
            const subtotal    = salePrice * quantity;
            const discountPct = Math.round(((regularPrice - salePrice) / regularPrice) * 100);
          %>

          <div class="cart-item"  data-id="<%= item.productId._id %>">

            <img
              src="/uploads/product-images/<%= item.productId.productImage?.[0] %>"
              alt="<%= item.productId.productName %>"
              class="item-img"
            />

            <div class="item-details">
              <a href="/productDetails?id=<%= item.productId._id %>" class="item-name">
                <%= item.productId.productName %>
              </a>
               <% if(item.stockStatus === 'Out of stock') { %>
                <p style="color:red;">Out of Stock</p>
              <% } %>
              <div class="item-meta">
                <% if (item.size) { %>Size: <%= item.size %> &nbsp;|&nbsp;<% } %>
                Category: <%= item.productId.category?.name || '—' %>
              </div>
              <div class="item-meta">
                <% if (item.size) { %>Size: <%= item.size %> &nbsp;|&nbsp;<% } %>
                Brand: <%= item.productId.brand?.brandName || '—' %>
              </div>
              <div class="item-price-row">
                <span class="item-sale">₹<%= salePrice.toLocaleString('en-IN') %></span>
                <span class="item-orig">₹<%= regularPrice.toLocaleString('en-IN') %></span>
                <span class="item-discount"><%= discountPct %>% off</span>
              </div>
              <div class="qty-row">
                <span class="qty-label">Quantity:</span>


                <div class="qty-ctrl">
                <button class="qty-btn"
                  <% if(item.isOutOfStock){ %> disabled <% } %>
                  onclick="updateQty('<%= item.productId._id %>', '<%= item.variant %>', -1, this, <%= salePrice %>
                  )">
                  −
                </button>

                <input class="qty-val"
                  value="<%= item.quantity %>"
                  <% if(item.isOutOfStock){ %> disabled <% } %>
                >

                <button class="qty-btn"
                  <% if(item.isOutOfStock){ %> disabled <% } %>
                  onclick="updateQty('<%= item.productId._id %>', '<%= item.variant %>', 1, this, <%= salePrice %>)">
                  +
                </button>
              </div>
              
              </div>
              <span class="qty-label">Size: <%= item.variant %></span>
             
            </div>

            <div class="item-actions">
              <a href="/removeFromCart?productId=<%= item.productId._id %>&variant=<%= item.variant %>" 
                 class="remove-item"
                 title="Remove item"
                 onclick="return confirmRemove(event, this.href)">
                ✕
              </a>
              <div>
                <div class="item-total-label">Subtotal</div>
                <div class="item-total">₹<%= subtotal.toLocaleString('en-IN') %></div>
              </div>
            </div>

          </div>

        <% }) %>

      <% } else { %>

        <div class="empty-cart">
          <div class="empty-icon"><i class="fas fa-shopping-bag"></i></div>
          <div class="empty-title">Your cart is empty</div>
          <div class="empty-sub">Looks like you haven't added anything yet.</div>
          <a href="/shop" class="shop-btn">Continue Shopping</a>
        </div>

      <% } %>
    </div>

    <!-- RIGHT: Order Summary -->
    <% if (cartItems.length > 0) { %>
    <div>
      <%
        const totalMRP      = cartItems.reduce((s, i) => s + i.productId.regularPrice * i.quantity, 0);
        const totalSale     = cartItems.reduce((s, i) => s + i.productId.salePrice    * i.quantity, 0);
        const totalDiscount = totalMRP - totalSale;
        const delivery      = totalSale >= 999 ? 0 : 99;
        const grandTotal    = totalSale + delivery;
      %>
      <div class="summary-card">
        <div class="summary-title">Order Summary</div>

        <div class="summary-row">
          <span>Price (<%= cartItems.length %> items)</span>
          <span class="cart-mrp">₹<%= totalMRP.toLocaleString('en-IN') %></span>
        </div>
        <div class="summary-row discount">
          <span>Discount</span>
          <span>− ₹<%= totalDiscount.toLocaleString('en-IN') %></span>
        </div>
        <div class="summary-row">
          <span>Delivery</span>
          <span style="color:<%= delivery === 0 ? '#2e7d32' : '#333' %>">
            <%= delivery === 0 ? 'FREE' : '₹' + delivery %>
          </span>
        </div>

        <!-- <div class="coupon-row">
          <input class="coupon-input" type="text" placeholder="Enter coupon code" id="couponCode">
          <button class="coupon-btn" onclick="applyCoupon()">Apply</button>
        </div> -->

        <div class="summary-row total">
          <span>Total Amount</span>
          <span class="grand-total">₹<%= grandTotal.toLocaleString('en-IN') %></span>
        </div>

        <a href="/checkout" class="checkout-btn">Proceed to Checkout</a>
        <a href="/shop" class="continue-link">← Continue Shopping</a>

        <div class="safe-badge">
          <i class="fas fa-lock" style="font-size:12px;"></i>
          Safe &amp; Secure Payments
        </div>
      </div>
    </div>
    <% } %>

  </div>
</main>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  function updateQty(itemId, variant, change, btn, price) {
    const input = btn.parentElement.querySelector('.qty-val');
     let currentQty = parseInt(input.value) || 1;
     let newQty = currentQty + change;
     if(newQty >10){
       Swal.fire({
        icon: 'warning',
        title: 'Limit reached',
        text: 'You can only add up to 10 items',
        confirmButtonText: 'OK'
      });
      return;
     }
     if (newQty < 1) {
      confirmRemove(null, `/removeFromCart?productId=${itemId}&variant=${variant}`);
      return;
    }

     input.value = newQty;
     fetch(`/updateCart?id=${itemId}&quantity=${newQty}&variant=${variant}`)
      .then(res => res.json())
      .then(data => {
        if (!data.success) {
          Swal.fire({
            icon: 'error',
            title: data.message || 'Update failed'
          });
        }else{
            const cartItem = btn.closest('.cart-item');
            const subtotalEl = cartItem.querySelector('.item-total');

            subtotalEl.textContent = '₹' + (price * newQty).toLocaleString('en-IN');

            const totalPrice = document.querySelector('.cart-mrp');
            const grandTotal = document.querySelector('.grand-total');

            totalPrice.textContent = '₹' + data.finalAmount.toLocaleString('en-IN');
            grandTotal.textContent = '₹' + data.finalAmount.toLocaleString('en-IN');
        }
      })
      .catch(() => {
        Swal.fire({
          icon: 'error',
          title: 'Network error'
        });
      });
  
  }

  function confirmRemove(e, url) {
    if (e) e.preventDefault();
    Swal.fire({
      title: 'Remove item?',
      text: 'This item will be removed from your cart.',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#d4145a',
      cancelButtonColor: '#aaa',
      confirmButtonText: 'Yes, remove it'
    }).then(result => {
      if (result.isConfirmed) window.location.href = url;
    });
  }

  function applyCoupon() {
    const code = document.getElementById('couponCode').value.trim();
    if (!code) {
      Swal.fire({ icon: 'warning', title: 'Enter a coupon code', confirmButtonColor: '#d4145a' });
      return;
    }
    window.location.href = '/applyCoupon?code=' + encodeURIComponent(code);
  }
</script>

<%- include("../../views/partials/user/footer") %>