<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Payment Failed</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />

  <style>
    body {
      background-color: #f8f9fa;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: Arial, sans-serif;
    }

    .failure-card {
      background: #fff;
      padding: 40px;
      border-radius: 20px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.08);
      text-align: center;
      max-width: 500px;
      width: 100%;
    }

    .failure-icon {
      font-size: 80px;
      color: #dc3545;
      margin-bottom: 20px;
    }

    .failure-title {
      font-size: 32px;
      font-weight: 700;
      color: #dc3545;
      margin-bottom: 15px;
    }

    .failure-text {
      color: #666;
      margin-bottom: 30px;
      font-size: 16px;
    }

    .btn-custom {
      padding: 12px 24px;
      border-radius: 10px;
      font-weight: 600;
      text-decoration: none;
      margin: 8px;
      display: inline-block;
    }

    .retry-btn {
      background-color: #d4145a;
      color: white;
    }

    .retry-btn:hover {
      background-color: #b0104c;
      color: white;
    }

    .details-btn {
      border: 1px solid #ccc;
      color: #333;
      background: white;
    }

    .details-btn:hover {
      background-color: #f1f1f1;
    }
  </style>
</head>

<body>

  <div class="failure-card">

    <div class="failure-icon">
      ❌
    </div>

    <h1 class="failure-title">
      Payment Failed
    </h1>

    <p class="failure-text">
      Your payment could not be completed.  
      Please try again or check your payment method.
    </p>

    <div>

      <a href="/retry-payment/<%= order._id %>"
         class="btn-custom retry-btn">
         Retry Payment
      </a>

      <a href="/orders/<%= order._id %>"
         class="btn-custom details-btn">
         View Order Details
      </a>

    </div>

  </div>

</body>
</html>