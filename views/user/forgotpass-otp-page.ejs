<%- include("../../views/partials/user/header") %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
  rel="stylesheet"
/>
<style>
  :root {
    --ink: #161413;
    --ink-soft: #6f6a67;
    --line: #e5e0dc;
    --pink: #c2185b;
    --pink-tint: #fdf2f6;
    --error: #b3261e;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: "Inter", sans-serif;
    background: #fbfaf9;
    height: 100vh;
    overflow: hidden;
    color: var(--ink);
  }

  main {
    height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .otp-container {
    width: 420px;
    max-width: 95vw;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 34px 42px;
    box-shadow: 0 20px 50px rgba(20, 18, 17, 0.06);
  }

  .icon-wrap {
    text-align: center;
    margin-bottom: 14px;
  }

  .icon-wrap i {
    font-size: 22px;
    color: var(--pink);
  }

  .form-heading {
    text-align: center;
    margin-bottom: 22px;
  }

  .form-heading h1 {
    font-size: 24px;
    font-weight: 800;
    letter-spacing: -0.01em;
    margin-bottom: 8px;
  }

  .form-heading p {
    font-size: 13px;
    color: var(--ink-soft);
    line-height: 1.6;
  }

  .form-group {
    margin-bottom: 6px;
  }

  .form-group label {
    display: block;
    font-size: 11.5px;
    color: var(--ink-soft);
    margin-bottom: 8px;
    font-weight: 500;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .form-group input {
    width: 100%;
    padding: 10px 10px;
    border: 1.5px solid var(--line);
    border-radius: 8px;
    font-size: 20px;
    letter-spacing: 8px;
    text-align: center;
    font-family: "Inter", sans-serif;
    color: var(--ink);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .form-group input::placeholder {
    color: #b8b2ac;
    letter-spacing: 6px;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--pink);
    box-shadow: 0 0 0 3px var(--pink-tint);
  }

  .error-msg {
    color: var(--error);
    font-size: 0.68rem;
    text-align: center;
    margin-top: 6px;
    min-height: 14px;
  }

  /* Timer */
  .timer-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin: 18px 0 16px;
  }

  .otp-timer {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 2px solid var(--pink);
    font-size: 12px;
    font-weight: 700;
    color: var(--pink);
    background: var(--pink-tint);
  }

  .timer-label {
    font-size: 12.5px;
    color: var(--ink-soft);
  }

  /* Buttons */
  .submit-btn {
    width: 100%;
    padding: 11px;
    background: var(--ink);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 13.5px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .submit-btn:hover {
    background: #c2185b;
  }

  .resend-btn {
    width: 100%;
    padding: 10px;
    background: #fff;
    color: var(--ink);
    border: 1.5px solid var(--line);
    border-radius: 8px;
    font-size: 12.5px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    margin-top: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .resend-btn:hover:not(:disabled) {
    border-color: var(--pink);
    background: var(--pink-tint);
    color: var(--pink);
  }

  .resend-btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .submit-btn:focus-visible,
  .resend-btn:focus-visible,
  .form-group input:focus-visible {
    outline: 2px solid var(--pink);
    outline-offset: 2px;
  }

  .alert-danger {
    color: var(--error);
    background: #fdf0ef;
    border: 1px solid #f3cfcc;
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 12.5px;
    text-align: center;
    margin-top: 14px;
  }

  .back-link {
    text-align: center;
    font-size: 13px;
    color: var(--ink-soft);
    margin-top: 18px;
  }

  .back-link a {
    color: var(--pink);
    font-weight: 600;
    text-decoration: none;
  }

  .back-link a:hover { text-decoration: underline; }

  /* Responsive */
  @media (max-width: 500px) {
    main { padding: 12px; }
    .otp-container { padding: 26px 24px; }
  }

  @media (max-height: 720px) {
    .otp-container { padding: 24px 40px; }
    .form-heading { margin-bottom: 14px; }
  }
</style>

<main>
    <div class="otp-container">

        <div class="icon-wrap">
            <i class="fas fa-shield-halved"></i>
        </div>

        <div class="form-heading">
            <h1>Email Verification</h1>
            <p>We've sent a 6-digit OTP to your email.<br>Enter it below to verify your account.</p>
        </div>

        <form id="otpForm" action="verify-passForgot-otp" method="POST" onsubmit="return validateOtp()">
            <div class="form-group">
                <label for="otp">Enter OTP</label>
                <input type="text" id="otp" name="otp" maxlength="6" placeholder="——————" autocomplete="one-time-code">
                <div class="error-msg" id="otpError"></div>
            </div>

            <div class="timer-row">
                <div class="otp-timer" id="otpTimer">60s</div>
                <span class="timer-label">Resend available after timer</span>
            </div>

            <button type="submit" class="submit-btn">
                <i class="fas fa-check-circle"></i>Verify OTP
            </button>
        </form>

        <button type="button" class="resend-btn" id="resendBtn" onclick="resendOtp()" disabled>
            <i class="fas fa-rotate-right"></i>Resend OTP
        </button>

        <% if (locals.message && message.length > 0) { %>
         <div class="alert-danger">
          <%=message%>
         </div>
        <% } %>

        <div class="back-link">
            Already verified? <a href="/login">Login now</a>
        </div>

    </div>
</main>

<script>
    // OTP Validation
    function validateOtp() {
        const otpInput = document.getElementById('otp');
        const otpError = document.getElementById('otpError');
        const value = otpInput.value.trim();

        otpError.textContent = '';
        otpInput.style.borderColor = '';

        if (value === '') {
            otpError.textContent = 'Please enter the OTP.';
            otpInput.style.borderColor = 'red';
            return false;
        } else if (!/^\d{6}$/.test(value)) {
            otpError.textContent = 'OTP must be a 6-digit number.';
            otpInput.style.borderColor = 'red';
            return false;
        }

        $.ajax({
          type : 'POST',
          url : '/verify-passForgot-otp',
          data : { otp : otpInput.value},
          success : function (response){
            if(response.success){
              Swal.fire({
                icon : 'success',
                title : 'OTP verified succesfully',
                timer : 1500,
                showConfirmButton : false
              }).then(()=>{
                window.location.href = response.redirectUrl;
              })
            }else{
              Swal.fire({
                icon : 'error',
                title : 'Error',
                text : 'Invalid OTP'
              })
            }
          },
          error : function(){
            Swal.fire({
              icon : 'error',
              title : 'Error',
              text : 'Failed to verify otp, please try again'
            })
          }
        })

        return false;
    }

    // Countdown Timer
    let seconds = 60;
    const timerEl = document.getElementById('otpTimer');
    const resendBtn = document.getElementById('resendBtn');

    const countdown = setInterval(() => {
        seconds--;
        timerEl.textContent = seconds + 's';
        if (seconds <= 0) {
            clearInterval(countdown);
            timerEl.textContent = '0s';
            resendBtn.disabled = false;
        }
    }, 1000);

     // ── Resend OTP ───────────────────────────────────────────────
    function resendOtp() {
        const resendBtn = document.getElementById('resendBtn');
        resendBtn.disabled = true;

        $.ajax({
            type: 'POST',
            url: '/resend-forgot-otp',        
            success: function (response) {
                if (response.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'OTP Resent!',
                        text: 'A new OTP has been sent to your email.',
                        timer: 2000,
                        showConfirmButton: false
                    });
                    document.getElementById('otp').value        = '';
                    document.getElementById('otpError').textContent = '';
                    startCountdown(); // restart 60s timer
                } else {
                    Swal.fire({ icon: 'error', title: 'Error', text: response.message || 'Could not resend OTP.' });
                    resendBtn.disabled = false;
                }
            },
            error: function () {
                Swal.fire({ icon: 'error', title: 'Error', text: 'Failed to resend OTP. Please try again.' });
                resendBtn.disabled = false;
            }
        });
    }

</script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<%- include("../../views/partials/user/footer") %>
