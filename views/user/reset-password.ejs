<%- include("../../views/partials/user/header") %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
  rel="stylesheet"
/>
<style>
  :root {
    --ink: #161413;
    --ink-soft: #6f6a67;
    --line: #e5e0dc;
    --pink: #c2185b;
    --pink-tint: #fdf2f6;
    --error: #b3261e;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: "Inter", sans-serif;
    background: #fbfaf9;
    height: 100vh;
    overflow: hidden;
    color: var(--ink);
  }

  main {
    height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .reset-container {
    width: 420px;
    max-width: 95vw;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 34px 42px;
    box-shadow: 0 20px 50px rgba(20, 18, 17, 0.06);
  }

  .icon-wrap {
    text-align: center;
    margin-bottom: 14px;
  }

  .icon-wrap i {
    font-size: 22px;
    color: var(--pink);
  }

  .form-heading {
    text-align: center;
    margin-bottom: 22px;
  }

  .form-heading h1 {
    font-size: 24px;
    font-weight: 800;
    letter-spacing: -0.01em;
    margin-bottom: 8px;
  }

  .form-heading p {
    font-size: 13px;
    color: var(--ink-soft);
    line-height: 1.6;
  }

  .alert-danger {
    background: #fdf0ef;
    border: 1px solid #f3cfcc;
    color: var(--error);
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 12.5px;
    text-align: center;
    margin-bottom: 16px;
  }

  .form-group {
    margin-bottom: 18px;
    position: relative;
  }

  .form-group label {
    display: block;
    font-size: 11.5px;
    color: var(--ink-soft);
    margin-bottom: 5px;
    font-weight: 500;
  }

  .form-group input {
    width: 100%;
    padding: 9px 34px 9px 10px;
    border: 1.5px solid var(--line);
    border-radius: 8px;
    font-size: 13.5px;
    font-family: "Inter", sans-serif;
    color: var(--ink);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .form-group input::placeholder {
    color: #b8b2ac;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--pink);
    box-shadow: 0 0 0 3px var(--pink-tint);
  }

  .toggle-eye {
    position: absolute;
    right: 10px;
    top: 31px;
    cursor: pointer;
    color: #b8b2ac;
    font-size: 13px;
    transition: color 0.2s;
  }

  .toggle-eye:hover { color: var(--pink); }

  .error-msg {
    color: var(--error);
    font-size: 0.68rem;
    margin-top: 4px;
    min-height: 12px;
  }

  /* Password strength bar */
  .strength-bar-wrap {
    margin-top: 8px;
    height: 4px;
    background: var(--pink-tint);
    border-radius: 4px;
    overflow: hidden;
  }

  .strength-bar {
    height: 100%;
    width: 0%;
    border-radius: 4px;
    transition: width 0.3s, background 0.3s;
  }

  .strength-label {
    font-size: 11px;
    color: var(--ink-soft);
    margin-top: 4px;
    text-align: right;
  }

  .submit-btn {
    width: 100%;
    padding: 11px;
    background: var(--ink);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 13.5px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 4px;
  }

  .submit-btn:hover {
    background: #000;
  }

  .submit-btn:focus-visible,
  .form-group input:focus-visible {
    outline: 2px solid var(--pink);
    outline-offset: 2px;
  }

  .back-link {
    text-align: center;
    font-size: 13px;
    color: var(--ink-soft);
    margin-top: 18px;
  }

  .back-link a {
    color: var(--pink);
    font-weight: 600;
    text-decoration: none;
  }

  .back-link a:hover { text-decoration: underline; }

  /* Responsive */
  @media (max-width: 500px) {
    main { padding: 12px; }
    .reset-container { padding: 26px 24px; }
  }

  @media (max-height: 720px) {
    .reset-container { padding: 24px 40px; }
    .form-heading { margin-bottom: 14px; }
  }
</style>

<main>
    <div class="reset-container">

        <div class="icon-wrap">
            <i class="fas fa-key"></i>
        </div>

        <div class="form-heading">
            <h1>Change Password</h1>
            <p>Choose a strong new password<br>to keep your account secure.</p>
        </div>

        <% if (locals.message && message.length > 0) { %>
            <div class="alert-danger"><%= message %></div>
        <% } %>

        <form id="changePassForm" action="/reset-password" method="POST" onsubmit="return validateForm()" novalidate>

            <!-- New Password -->
            <div class="form-group">
                <label for="newPass1">New Password</label>
                <input type="password" name="newPass1" id="newPass1" placeholder="••••••••">
                <i class="fas fa-eye toggle-eye" onclick="toggleVisibility('newPass1', this)"></i>
                <div class="strength-bar-wrap">
                    <div class="strength-bar" id="strengthBar"></div>
                </div>
                <div class="strength-label" id="strengthLabel"></div>
                <div class="error-msg" id="newPass1Error"></div>
            </div>

            <!-- Confirm Password -->
            <div class="form-group">
                <label for="newPass2">Re-enter New Password</label>
                <input type="password" name="newPass2" id="newPass2" placeholder="••••••••">
                <i class="fas fa-eye toggle-eye" onclick="toggleVisibility('newPass2', this)"></i>
                <div class="error-msg" id="newPass2Error"></div>
            </div>

            <button type="submit" class="submit-btn">
                <i class="fas fa-lock"></i>Update Password
            </button>
        </form>

        <div class="back-link">
            Don't have an account? <a href="/signup">Sign up</a>
        </div>

    </div>
</main>

<script>
    // Toggle password visibility
    function toggleVisibility(fieldId, icon) {
        const input = document.getElementById(fieldId);
        const isPassword = input.type === 'password';
        input.type = isPassword ? 'text' : 'password';
        icon.classList.toggle('fa-eye', !isPassword);
        icon.classList.toggle('fa-eye-slash', isPassword);
    }

    // Password strength indicator
    document.getElementById('newPass1').addEventListener('input', function () {
        const val = this.value;
        const bar = document.getElementById('strengthBar');
        const label = document.getElementById('strengthLabel');
        let strength = 0;

        if (val.length >= 6) strength++;
        if (/[A-Z]/.test(val)) strength++;
        if (/[0-9]/.test(val)) strength++;
        if (/[^A-Za-z0-9]/.test(val)) strength++;

        const levels = [
            { width: '0%',   color: '#eee',     text: '' },
            { width: '30%',  color: '#e74c3c',  text: 'Weak' },
            { width: '60%',  color: '#f39c12',  text: 'Fair' },
            { width: '80%',  color: '#2ecc71',  text: 'Good' },
            { width: '100%', color: '#27ae60',  text: 'Strong' },
        ];

        bar.style.width = levels[strength].width;
        bar.style.background = levels[strength].color;
        label.textContent = levels[strength].text;
        label.style.color = levels[strength].color;
    });

    // Form validation
    function validateForm() {
        let valid = true;
        const newPass1 = document.getElementById('newPass1');
        const newPass2 = document.getElementById('newPass2');
        const newPass1Error = document.getElementById('newPass1Error');
        const newPass2Error = document.getElementById('newPass2Error');

        newPass1Error.textContent = '';
        newPass2Error.textContent = '';
        newPass1.style.borderColor = '';
        newPass2.style.borderColor = '';

        if (!newPass1.value.trim()) {
            newPass1Error.textContent = 'Password cannot be empty.';
            newPass1.style.borderColor = 'red';
            valid = false;
        } else if (newPass1.value.length < 6) {
            newPass1Error.textContent = 'Password must be at least 6 characters.';
            newPass1.style.borderColor = 'red';
            valid = false;
        }

        if (!newPass2.value.trim()) {
            newPass2Error.textContent = 'Please re-enter your password.';
            newPass2.style.borderColor = 'red';
            valid = false;
        } else if (newPass2.value !== newPass1.value) {
            newPass2Error.textContent = 'Passwords do not match.';
            newPass2.style.borderColor = 'red';
            valid = false;
        }

        return valid;
    }

</script>

<%- include("../../views/partials/user/footer") %>
