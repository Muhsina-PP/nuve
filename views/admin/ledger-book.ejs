<%- include("../../views/partials/admin/header") %>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<style>
  :root {
    --primary: #eb2f7e;
    --primary-dark: #c41263;
    --primary-light: rgba(235, 47, 126, 0.08);
    --light-bg: #fdf4f8;
    --card-bg: #ffffff;
    --text: #1a0a12;
    --text-muted: #8a5a72;
    --border: #ffd6e8;
    --radius: 16px;
    --shadow: 0 8px 30px rgba(235, 47, 126, 0.1);
  }

  body {
    background-color: var(--light-bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
  }

  .ledger-wrap {
    padding: 2.5rem;
  }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .page-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 700;
  }

  .page-title span {
    color: var(--primary);
  }

  .action-btns {
    display: flex;
    gap: 1rem;
  }

  .btn-export {
    padding: 0.8rem 1.5rem;
    border-radius: 50px;
    border: 2px solid var(--border);
    background: white;
    color: var(--text);
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .btn-export:hover {
    border-color: var(--primary);
    color: var(--primary);
    background: var(--primary-light);
  }

  .btn-export.pdf:hover {
    border-color: #ff4d4d;
    color: #ff4d4d;
    background: rgba(255, 77, 77, 0.05);
  }

  .btn-export.excel:hover {
    border-color: #27ae60;
    color: #27ae60;
    background: rgba(39, 174, 96, 0.05);
  }

  .ledger-card {
    background: white;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .table-responsive {
    overflow-x: auto;
  }

  .ledger-table {
    width: 100%;
    border-collapse: collapse;
  }

  .ledger-table thead {
    background: linear-gradient(90deg, var(--primary), var(--primary-dark));
    color: white;
  }

  .ledger-table th {
    padding: 1.2rem 1rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ledger-table td {
    padding: 1rem;
    border-bottom: 1px solid #f0f0f0;
    font-size: 0.95rem;
  }

  .ledger-table tbody tr:hover {
    background-color: var(--primary-light);
  }

  .status-badge {
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: capitalize;
  }

  .status-delivered { background: #e6fffa; color: #234e52; }
  .status-cancelled { background: #fff5f5; color: #822727; }
  .status-pending   { background: #fffaf0; color: #744210; }
  .status-returned  { background: #edf2f7; color: #2d3748; }

  .amount-positive { color: #27ae60; font-weight: 700; }
  .amount-negative { color: #e74c3c; }

  .summary-footer {
    padding: 1.5rem;
    background: #fafafa;
    display: flex;
    justify-content: flex-end;
    gap: 3rem;
    font-weight: 700;
    font-size: 1.1rem;
    border-top: 2px solid var(--border);
  }

  .summary-item span {
    color: var(--text-muted);
    font-weight: 500;
    margin-right: 0.5rem;
  }
</style>

<div class="ledger-wrap">
  <div class="page-header">
    <h1 class="page-title">Ledger <span>Book</span></h1>
    <div class="action-btns">
      <button class="btn-export pdf" onclick="downloadPDF()">
        <i class="fas fa-file-pdf"></i> Download PDF
      </button>
      <button class="btn-export excel" onclick="downloadExcel()">
        <i class="fas fa-file-excel"></i> Download Excel
      </button>
    </div>
  </div>

  <div class="ledger-card">
    <div class="table-responsive">
      <table class="ledger-table" id="ledgerTable">
        <thead>
          <tr>
            <th>Order ID</th>
            <th>Date</th>
            <th>Customer</th>
            <th>Payment</th>
            <th>Total</th>
            <th>Discount</th>
            <th>Coupon</th>
            <th>Wallet</th>
            <th>GST</th>
            <th>Final Amount</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% if (data && data.length > 0) { %>
            <% data.forEach(item => { %>
              <tr>
                <td><strong>#<%= item.orderId %></strong></td>
                <td><%= item.date %></td>
                <td><%= item.customer %></td>
                <td><%= item.paymentMethod %></td>
                <td>₹<%= item.totalPrice.toLocaleString() %></td>
                <td class="amount-negative">-₹<%= item.discount.toLocaleString() %></td>
                <td class="amount-negative">-₹<%= item.couponDiscount.toLocaleString() %></td>
                <td class="amount-negative">-₹<%= item.walletUsed.toLocaleString() %></td>
                <td>₹<%= item.gstAmount.toLocaleString() %></td>
                <td class="amount-positive">₹<%= item.finalAmount.toLocaleString() %></td>
                <td>
                  <span class="status-badge status-<%= item.status.toLowerCase().replace(' ', '-') %>">
                    <%= item.status %>
                  </span>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="11" style="text-align: center; padding: 3rem;">No transactions found.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="summary-footer">
      <div class="summary-item">
        <span>Total Transactions:</span> <%= data.length %>
      </div>
      <div class="summary-item">
        <span>Net Revenue:</span> 
        <span class="amount-positive">
          ₹<%= data.reduce((acc, curr) => acc + curr.finalAmount, 0).toLocaleString() %>
        </span>
      </div>
    </div>
  </div>
</div>

<script>
  function downloadPDF() {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF('landscape');
    
    doc.text("Nuve - Ledger Book", 14, 15);
    doc.setFontSize(10);
    doc.text(`Generated on: ${new Date().toLocaleString()}`, 14, 22);
    
    doc.autoTable({
      html: '#ledgerTable',
      startY: 30,
      theme: 'grid',
      headStyles: { fillStyle: [235, 47, 126] },
      styles: { fontSize: 8 }
    });
    
    doc.save("Nuve-Ledger-Book.pdf");
  }

  function downloadExcel() {
    const table = document.getElementById("ledgerTable");
    const wb = XLSX.utils.table_to_book(table, { sheet: "Ledger" });
    XLSX.writeFile(wb, "Nuve-Ledger-Book.xlsx");
  }
</script>

<%- include("../../views/partials/admin/footer") %>
