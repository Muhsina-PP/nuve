    }
  })
  .catch(() => {
    Swal.fire({ icon: 'error', title: 'Network error' });
  });
  });
  

  function validateForm() {
    let isValid = true;
    const fields = [
      { id: "addressType", name: "Address Type" },
      { id: "name", name: "Full Name" },
      { id: "city", name: "City" },
      { id: "landMark", name: "Landmark" },
      { id: "state", name: "State" },
      { id: "pincode", name: "Pincode" },
      { id: "phone", name: "Phone Number" },
      { id: "altPhone", name: "Alternate Phone" }
    ];

    fields.forEach(field => {
      const input = document.getElementById(field.id);
      const value = input.value.trim();
      const errorElement = document.getElementById(field.id + '-error');

      // Clear previous error
      if (errorElement) errorElement.textContent = '';

      if (!value) {
        if (!errorElement) {
          const err = document.createElement('div');
          err.id = field.id + '-error';
          err.className = 'error-msg';
          err.textContent = `${field.name} is required.`;
          input.parentNode.appendChild(err);
        } else {
          errorElement.textContent = `${field.name} is required.`;
        }
        isValid = false;
      }
    });

    // Additional validations
    const name = document.getElementById('name').value.trim();
    const city = document.getElementById('city').value.trim();
    const landMark = document.getElementById('landMark').value.trim();
    const state = document.getElementById('state').value.trim();
    const pincode = document.getElementById('pincode').value.trim();
    const phone = document.getElementById('phone').value.trim();
    const altPhone = document.getElementById('altPhone').value.trim();

    const alphaPattern = /^[A-Za-z\s]+$/;
    const pinPattern = /^\d{6}$/;
    const phonePattern = /^\d{10}$/;

    if (name && !alphaPattern.test(name)) {
      Swal.fire({ icon: 'error', title: 'Invalid Name', text: 'Name should contain alphabets only.' });
      isValid = false;
    }
    if (city && !alphaPattern.test(city)) {
      Swal.fire({ icon: 'error', title: 'Invalid City', text: 'City should contain alphabets only.' });
      isValid = false;
    }
    if (landMark && !alphaPattern.test(landMark)) {
      Swal.fire({ icon: 'error', title: 'Invalid Landmark', text: 'Landmark should contain alphabets only.' });
      isValid = false;
    }
    if (state && !alphaPattern.test(state)) {
      Swal.fire({ icon: 'error', title: 'Invalid State', text: 'State should contain alphabets only.' });
      isValid = false;
    }
    if (pincode && !pinPattern.test(pincode)) {
      Swal.fire({ icon: 'error', title: 'Invalid Pincode', text: 'Pincode must be exactly 6 digits.' });
      isValid = false;
    }
    if (phone && !phonePattern.test(phone)) {
      Swal.fire({ icon: 'error', title: 'Invalid Phone', text: 'Phone number must be exactly 10 digits.' });
      isValid = false;
    }
    if (altPhone && !phonePattern.test(altPhone)) {
      Swal.fire({ icon: 'error', title: 'Invalid Alternate Phone', text: 'Alternate phone must be exactly 10 digits.' });
      isValid = false;
    }
    if (phone && altPhone && phone === altPhone) {
      Swal.fire({ icon: 'error', title: 'Duplicate Phone', text: 'Phone and Alternate Phone cannot be the same.' });
      isValid = false;
    }

    return isValid;
  }
</script>

